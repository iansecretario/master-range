def wait_for_idle_runcommand(rg, name, max_wait_s=600):
    # Poll 'az vm run-command list' until no Provisioning/Updating
    # RunCommand is reported on the VM. This prevents the legacy
    # 'az vm run-command invoke' from being rejected with the
    # 'Run command extension execution is in progress' Conflict
    # error when terraform's managed azurerm_virtual_machine_run_command
    # resource is still finishing on a freshly-applied VM.
    # NOTE: NO BACKTICKS in any comment in this block. The whole Python
    # source is passed through bash's double-quoted heredoc -- bash
    # would execute backtick contents as a command substitution
    # before Python ever sees the source.
    deadline = time.time() + max_wait_s
    while time.time() < deadline:
        r = subprocess.run([
            'az','vm','run-command','list',
            '-g', rg, '--vm-name', name,
            '-o','json',
        ], capture_output=True, text=True, timeout=60)
        if r.returncode != 0:
            # 'list' itself can return non-zero on some Azure regions
            # if the VM has zero managed RunCommands — that's fine,
            # nothing to wait for, proceed immediately.
            return True
        try:
            cmds = json.loads(r.stdout or '[]')
        except Exception:
            return True
        busy = []
        for c in cmds or []:
            ps = (c.get('provisioningState') or '').lower()
            if ps in ('creating','updating','running','provisioning'):
                busy.append(c.get('name','?'))
        if not busy:
            return True
        print(f'  [busy] {name}: managed RunCommand(s) still in flight: '
              f'{\",\".join(busy)} — waiting 30s')
        time.sleep(30)
    return False

def invoke_with_retry(rg, name, script, role, max_attempts=3):
    # Azure rejects a legacy 'az vm run-command invoke' while a managed
    # azurerm_virtual_machine_run_command (or earlier legacy invoke)
    # is still executing on the same VM:
    #   ERROR: (Conflict) Run command extension execution is in progress.
    #   Please wait for completion before invoking a run command.
    # Terraform's managed RunCommand can take 5-10 min on first apply
    # (Sliver cloud-init pulls + unpacks the BishopFox binary, etc).
    # So we retry with progressive backoff: 30s, 60s, 90s.
    # NOTE: max_attempts reduced to 3 (from 6) because the outer
    # _do_repair_with_retry already iterates the WHOLE pass up to 3
    # times -- compound retries multiplied the wall-clock budget.
    tmo = role_timeout(role)
    last_stderr = ''
    for attempt in range(1, max_attempts + 1):
        r = subprocess.run([
            'az','vm','run-command','invoke',
            '-g', rg, '-n', name,
            '--command-id','RunShellScript',
            '--scripts', script,
            '--query','value[0].message',
            '-o','tsv',
        ], capture_output=True, text=True, timeout=tmo)
        stderr = r.stderr or ''
        if r.returncode == 0:
            return r.stdout or '', ''
        if 'Conflict' in stderr and 'in progress' in stderr:
            wait_s = 30 * attempt
            time.sleep(wait_s)
            last_stderr = stderr
            continue
        # Non-Conflict failure: return immediately so the operator sees it.
        return r.stdout or '', stderr
    # ---- Conflict persisted across all in-loop retries ----
    # Almost always means a previous LEGACY 'az vm run-command invoke'
    # is wedged in the VM agent's extension slot (typically Sliver,
    # which downloads a large binary and can outlive our client-side
    # timeout). 'az vm run-command list' won't show it -- the only
    # way to clear that slot is to reboot the VM. We do this ONLY for
    # the Sliver role; rebooting Adaptix mid-build would discard work.
    if role == 'c2-sliver':
        reboot_msg = (f'  [conflict-recover] {name}: legacy RunCommand slot '
                      f'wedged after {max_attempts} retries — rebooting VM '
                      f'to clear it (takes ~60s)')
        rb = subprocess.run(
            ['az','vm','restart','-g', rg, '-n', name, '--no-wait'],
            capture_output=True, text=True, timeout=60)
        if rb.returncode != 0:
            return '', (last_stderr +
                        '\n  [conflict-recover] reboot also failed: ' +
                        (rb.stderr or '')[:300])
        # Wait for the agent to come back. 90s is typical for a small
        # Linux VM. Then try the invoke ONE more time.
        time.sleep(90)
        r = subprocess.run([
            'az','vm','run-command','invoke',
            '-g', rg, '-n', name,
            '--command-id','RunShellScript',
            '--scripts', script,
            '--query','value[0].message',
            '-o','tsv',
        ], capture_output=True, text=True, timeout=tmo)
        if r.returncode == 0:
            return (reboot_msg + '\n' + (r.stdout or '')), ''
        return r.stdout or '', (reboot_msg + '\n' + (r.stderr or ''))
    return '', last_stderr or '  exhausted retries (Conflict persisted)'

