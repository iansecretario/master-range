        ], capture_output=True, text=True, timeout=180)
        print(r.stdout[:8000] if r.stdout else '(empty)')
        if r.returncode != 0:
            print('STDERR:', r.stderr[:300])
    except subprocess.TimeoutExpired:
        print('  TIMEOUT (180s) — VM agent likely unresponsive')
"
    ;;

  bake)
    # One-time per-quarter image baking. Runs Packer against your Azure
    # sub to build a generalized Server 2022 image with:
    #   - AD-DS + DNS roles pre-installed (skip ~5 min per deploy)
    #   - WinRM + RDP firewall rules baked in
    #   - NetworkCategory set to Private (avoids Public-profile WinRM bug)
    #   - Latest Windows Updates applied (skip ~15 min per deploy)
    #   - Windows Update services disabled (deploys don't re-pull patches)
    #
    # After this completes, set `baking.enabled: true` in your scenario
    # YAML (or pass --baking) and re-apply. Deploys drop from ~45 min to
    # ~10 min.
    #
    # Cost: ~$0.10 of build-VM compute, ~30 min wall time. Storage of
    # the resulting SIG image: ~$0.50/mo.
    command -v packer >/dev/null 2>&1 || die "packer not installed — brew install packer / https://developer.hashicorp.com/packer/install"
    command -v az     >/dev/null 2>&1 || die "az CLI required"

    target="${1:-server-2022}"
    case "$target" in
      server-2025|win-server-2025|server-2022|win-server-2022|server-2019|win-server-2019|win-10|win10|win-11|win11|kali|kali-minimal|elk|redelk|debian-redirector|redirector|guacamole|guac|adaptix|mythic|sliver|ghostwriter|stepping-stones|stepping_stones|all) ;;
      *) die "unknown bake target: $target (supported: server-2025, server-2022, server-2019, win-10, win-11, kali, kali-minimal, elk, redelk, debian-redirector, guacamole, adaptix, mythic, sliver, ghostwriter, stepping-stones, all)" ;;
    esac

    # ----- Provider dispatch for the bake subcommand -----
    # GCP path: use `packer build <image>.gcp.pkr.hcl`, no SIG-slot
    # bootstrap (GCP images are flat in projects/<host>/global/images).
    # Bail early with a GCP-specific code path; Azure logic continues
    # below as before.
    if [[ "$PROVIDER" == "gcp" ]]; then
      command -v gcloud >/dev/null 2>&1 || die "gcloud not on PATH — install Google Cloud SDK + 'gcloud auth application-default login' before baking GCP images"
      command -v packer >/dev/null 2>&1 || die "packer not installed — brew install packer / https://developer.hashicorp.com/packer/install"

      host_project="${TERRARANGE_GCP_HOST_PROJECT_ID:-}"
      [[ -n "$host_project" ]] || die "TERRARANGE_GCP_HOST_PROJECT_ID env var not set — baked images need a long-lived host project (see docs/GCP_PARITY_ROADMAP.md)"
      gcp_region="${TERRARANGE_GCP_REGION:-asia-southeast1}"

      # Resolve target → (template dir, image family) pair. Mirror of
      # the Azure dispatch below but routes to the .gcp.pkr.hcl files.
      case "$target" in
        server-2022|win-server-2022)    pkr_dir="win-server-2022";   pkr_file="win-server-2022-ad.gcp.pkr.hcl";   img_family="win-server-2022-ad" ;;
        server-2025|win-server-2025)    pkr_dir="win-server-2025";   pkr_file="win-server-2025.gcp.pkr.hcl";      img_family="win-server-2025" ;;
        server-2019|win-server-2019)    pkr_dir="win-server-2019";   pkr_file="win-server-2019.gcp.pkr.hcl";      img_family="win-server-2019" ;;
        win-10|win10)                   pkr_dir="win-10";            pkr_file="win-10.gcp.pkr.hcl";               img_family="win-10" ;;
        win-11|win11)                   pkr_dir="win-11";            pkr_file="win-11.gcp.pkr.hcl";               img_family="win-11" ;;
        kali)                           pkr_dir="kali";              pkr_file="kali-redteam.gcp.pkr.hcl";         img_family="kali-redteam" ;;
        kali-minimal)                   pkr_dir="kali-minimal";      pkr_file="kali-minimal.gcp.pkr.hcl";         img_family="kali-minimal" ;;
        elk)                            pkr_dir="elk";               pkr_file="elk.gcp.pkr.hcl";                  img_family="elk" ;;
        redelk)                         pkr_dir="redelk";            pkr_file="redelk.gcp.pkr.hcl";               img_family="redelk" ;;
        debian-redirector|redirector)   pkr_dir="debian-redirector"; pkr_file="debian-redirector.gcp.pkr.hcl";    img_family="debian-redirector" ;;
        guacamole|guac)                 pkr_dir="guacamole";         pkr_file="guacamole.gcp.pkr.hcl";            img_family="guacamole" ;;
        adaptix)                        pkr_dir="adaptix";           pkr_file="adaptix.gcp.pkr.hcl";              img_family="adaptix" ;;
        mythic)                         pkr_dir="mythic";            pkr_file="mythic.gcp.pkr.hcl";               img_family="mythic" ;;
        sliver)                         pkr_dir="sliver";            pkr_file="sliver.gcp.pkr.hcl";               img_family="sliver" ;;
        ghostwriter)                    pkr_dir="ghostwriter";       pkr_file="ghostwriter.gcp.pkr.hcl";          img_family="ghostwriter" ;;
        stepping-stones|stepping_stones) pkr_dir="stepping-stones";  pkr_file="stepping-stones.gcp.pkr.hcl";      img_family="stepping-stones" ;;
        all)                            die "[bake] 'all' on GCP not yet wired — bake one target at a time" ;;
        *)                              die "[bake] unknown GCP target: $target" ;;
      esac

      pkr_path="$REPO/packer/$pkr_dir"
      [[ -f "$pkr_path/$pkr_file" ]] || die "[bake] template not found: $pkr_path/$pkr_file"

      bold "  [bake/gcp] target=$target  host_project=$host_project  region=$gcp_region"
      bold "  [bake/gcp] family=$img_family  template=$pkr_path/$pkr_file"
      echo

      # Probe whether the image family already has a non-deprecated image.
      # Informational only; we always bake (deprecating older versions
      # at end of bake is handled by Packer's googlecompute builder).
      latest=$(gcloud compute images describe-from-family "$img_family" \
        --project="$host_project" --format='value(name)' 2>/dev/null || true)
      if [[ -n "$latest" ]]; then
        bold "  [bake/gcp] existing latest in family: $latest"
        bold "  [bake/gcp]   (Packer will publish a NEW version + deprecate this one)"
      else
        bold "  [bake/gcp] family '$img_family' has no images yet — first bake"
      fi
      echo

      version="$(date +%Y%m%d-%H%M%S)"
      bold "  [bake/gcp] packer init ..."
      packer init "$pkr_path/$pkr_file" || die "packer init failed"

      bold "  [bake/gcp] packer build (~20-45 min depending on target) ..."
      packer build -force \
        -var "gcp_project_id=$host_project" \
        -var "gcp_region=$gcp_region" \
        -var "image_family=$img_family" \
        -var "image_version=$version" \
        "$pkr_path/$pkr_file" \
        || die "packer build failed for $target"

      bold ""
      bold "[bake/gcp] complete — new image published to family '$img_family' in project '$host_project'"
      bold "  Next: flip use_baked_$target → true in the baking: block of your scenario YAML, then ./range --provider gcp apply <scenario>"
      exit 0
    fi

    sub_id=$(az account show --query id -o tsv)
    [[ -n "$sub_id" ]] || die "az account show failed — run 'az login' first"

    # Resolve target → SIG image_definition name (must match baking.tf).
    # Used below to (a) auto-create the SIG slot if missing, and (b) pass
    # to packer as -var image_definition=<def>.
    case "$target" in
      server-2022|win-server-2022)   image_def="win-server-2022-ad" ;;
      server-2025|win-server-2025)   image_def="win-server-2025" ;;
      server-2019|win-server-2019)   image_def="win-server-2019" ;;
      win-10|win10)                  image_def="win-10" ;;
      win-11|win11)                  image_def="win-11" ;;
      kali)                          image_def="kali-redteam" ;;
      kali-minimal)                  image_def="kali-minimal" ;;
      elk)                           image_def="elk" ;;
      redelk)                        image_def="redelk" ;;
      debian-redirector|redirector)  image_def="debian-redirector" ;;
      guacamole|guac)                image_def="guacamole" ;;
      adaptix)                       image_def="adaptix" ;;
      mythic)                        image_def="mythic" ;;
      sliver)                        image_def="sliver" ;;
      ghostwriter)                   image_def="ghostwriter" ;;
      stepping-stones|stepping_stones) image_def="stepping-stones" ;;
      all)                           image_def="" ;;   # handled by per-iteration logic below
    esac

    # Auto-ensure the SIG infra + the specific image-definition slot
    # exist BEFORE we hand off to packer. Packer's
    # `shared_image_gallery_destination` block 404s if the slot isn't
    # there, which is exactly the error the operator was seeing on a
    # fresh sub or after baking.tf added new image definitions that
    # weren't yet applied.
    #
    # Requires the active envs/azure/terraform.tfvars.json to have
    # `baking.enabled: true` — the image-def resources are gated by
    # that flag. If it's false, we flip it for this targeted apply only
    # by writing a tiny override file (terraform's -var-file= takes
    # precedence over the auto-loaded terraform.tfvars.json).
    cd "$ENV_DIR"
    [[ -d .terraform ]] || terraform init -upgrade >/dev/null

    if [[ "$target" != "all" ]] && command -v az >/dev/null 2>&1; then
      sig_rg="terra-range-images-rg"
      sig_name="terra_range_images"
      if az sig image-definition show -g "$sig_rg" -r "$sig_name" \
            -i "$image_def" >/dev/null 2>&1; then
        bold "  [bake] SIG slot '$image_def' already exists — skipping bootstrap apply."
      else
        bold "  [bake] SIG slot '$image_def' missing — running targeted terraform apply (~1-2 min)..."
        # Write an override that guarantees baking.enabled=true. If the
        # active tfvars already has it true, this is a no-op override.
        override_tfvars=$(mktemp -t range-bake-override.XXXXXX.tfvars.json)
        # shellcheck disable=SC2064
        trap "rm -f '$override_tfvars'" EXIT
        # Read the existing baking object (so we don't drop sibling
        # fields like use_baked_*), force enabled=true, write back.
        python3 - "$override_tfvars" <<PY
import json, sys, pathlib
out_path = sys.argv[1]
tfvars = pathlib.Path("terraform.tfvars.json")
existing = {}
if tfvars.exists():
    try:
        existing = (json.loads(tfvars.read_text()).get("baking") or {})
    except Exception:
        existing = {}
existing["enabled"] = True
json.dump({"baking": existing}, open(out_path, "w"))
PY
        terraform apply -auto-approve \
          -var-file="$override_tfvars" \
          -target="module.range.azurerm_resource_group.baking[0]" \
          -target="module.range.azurerm_shared_image_gallery.main[0]" \
          -target="module.range.azurerm_shared_image.${image_def//-/_}[0]" \
          || die "[bake] targeted apply for SIG slot '$image_def' failed. Inspect with 'terraform apply -target=module.range.azurerm_shared_image.${image_def//-/_}[0]' in $ENV_DIR."
        rm -f "$override_tfvars"
        trap - EXIT
        bold "  [bake] SIG slot '$image_def' ready."
      fi
    fi

    region=$(awk '/^azure_region:/{print $2}' "$REPO/scenarios/${target/-/-}.yaml" 2>/dev/null \
              || echo southeastasia)
    region="${region:-southeastasia}"

    bold "Running Packer build(s) for target: $target ..."
    cd "$REPO/packer"
    # Timestamped image version so versions roll forward; terraform's
    # data.azurerm_shared_image_version always reads "latest".
    version="$(date +%Y).$(date +%m).$(date +%d)"
    bold "  Image version: $version"
    # Build one Packer template into the SIG. $1 = template SUBDIR under
    # packer/ — each template lives in its OWN directory so packer parses
    # it in isolation. (Both templates declare the same `variable` names;
    # co-located in one dir, packer's directory glob sees each name twice
    # → "Duplicate variable", and `packer init` dies before any build
    # starts.) $2 = image_definition name — MUST match the
    # azurerm_shared_image `name` in modules/azure/baking.tf so terraform
    # reads it back.
    _bake_one() {
      # $1 = template subdir name (e.g. "win-server-2025", "kali")
      # $2 = image_definition name AND base filename of the Azure template
      #      (e.g. "win-server-2025", "kali-redteam") — they happen to be
      #      the same except for the kali/win-server-2022 cases handled
      #      by the dispatch case above.
      #
      # CRITICAL: pass the SPECIFIC .pkr.hcl file (not the directory) to
      # packer init/build. Reason: when the GCP Phase B port landed, each
      # template directory now contains BOTH `<base>.pkr.hcl` (Azure) AND
      # `<base>.gcp.pkr.hcl` (GCP). Packer parses every `*.pkr.hcl` in a
      # directory by default and emits "Duplicate variable" errors
      # because both files declare `variable "vm_size"`, `image_version`,
      # etc. Pointing at the SPECIFIC file restricts the parse to just
      # the Azure template. The GCP bake branch (above) similarly passes
      # only its `.gcp.pkr.hcl` filename. The .gcp variant doesn't break
      # `packer init <file>` of the Azure variant because packer is
      # explicitly told which file to parse.
      local pkr_file="$1/$2.pkr.hcl"
      [[ -f "$pkr_file" ]] || die "Azure packer template not found: $pkr_file (cwd=$PWD)"
      bold "  → packer init + build: $2  (~30-40 min)..."
      packer init "$pkr_file" || die "packer init failed for $2"
      # -force: auto-delete stale temp managed image / VHD from a
      # previous run that failed mid-flight (e.g. SIG slot missing,
      # interrupted packer, transient Azure error). Without -force,
      # packer aborts with "managed image ... already exists" and the
      # operator has to delete it manually via:
      #   az image delete -g terra-range-images-rg -n <image>-tmp
      # which is a footgun on retries. Safe to use here because each
      # bake target has a deterministic temp name and we own the RG.
      packer build -force \
        -var "azure_subscription_id=$sub_id" \
        -var "azure_region=$region" \
        -var "sig_resource_group=terra-range-images-rg" \
        -var "sig_name=terra_range_images" \
        -var "image_definition=$2" \
        -var "image_version=$version" \
        "$pkr_file" || die "packer build failed for $2"
    }

    # Template-subdir → image-definition mapping. Each `_bake_one <dir>
    # <image_def>` invocation: <dir> is the subdir under packer/ that
    # contains exactly one .pkr.hcl template; <image_def> is the
    # `azurerm_shared_image.<name>` resource's `name` attribute in
    # modules/azure/baking.tf — terraform reads back the latest version
    # of that exact image_def.
    case "$target" in
      server-2022|win-server-2022)
        _bake_one win-server-2022 win-server-2022-ad ;;
      server-2025|win-server-2025)
        _bake_one win-server-2025 win-server-2025 ;;
      server-2019|win-server-2019)
        _bake_one win-server-2019 win-server-2019 ;;
      win-10|win10)
        _bake_one win-10 win-10 ;;
      win-11|win11)
        _bake_one win-11 win-11 ;;
      kali)
        _bake_one kali kali-redteam ;;
      kali-minimal)
        _bake_one kali-minimal kali-minimal ;;
      elk)
        _bake_one elk elk ;;
      redelk)
        _bake_one redelk redelk ;;
      debian-redirector|redirector)
        _bake_one debian-redirector debian-redirector ;;
      guacamole|guac)
        _bake_one guacamole guacamole ;;
      adaptix)
        _bake_one adaptix adaptix ;;
      mythic)
        _bake_one mythic mythic ;;
      sliver)
        _bake_one sliver sliver ;;
      ghostwriter)
        _bake_one ghostwriter ghostwriter ;;
      stepping-stones|stepping_stones)
        _bake_one stepping-stones stepping-stones ;;
      all)
        # All baked images in one shot. ~3-4 hours wall time
        # (sequential per `_bake_one`). Run with screen/tmux if you
        # want to walk away. Order: cheapest first so a fast SIG
        # update is visible early, expensive Windows bakes last.
        _bake_one debian-redirector debian-redirector
        _bake_one sliver            sliver
        _bake_one stepping-stones   stepping-stones
        _bake_one guacamole         guacamole
        _bake_one adaptix           adaptix
        _bake_one mythic            mythic
        _bake_one ghostwriter       ghostwriter
        _bake_one kali              kali-redteam
        _bake_one elk               elk
        _bake_one redelk            redelk
        _bake_one win-server-2022   win-server-2022-ad
        _bake_one win-server-2025   win-server-2025
        _bake_one win-server-2019   win-server-2019
        _bake_one win-10            win-10
        _bake_one win-11            win-11 ;;
    esac

    bold ""
    bold "Bake complete. To DEPLOY from this image, flip the matching"
    bold "use_baked_* flag in your scenario YAML's baking: block, then"
    bold "./range apply:"
    bold ""
    bold "    baking:"
    bold "      enabled: true"
    bold "      use_baked_kali:              true  # after baking kali"
    bold "      use_baked_guacamole:         true  # after baking guacamole"
    bold "      use_baked_adaptix:           true  # after baking adaptix"
    bold "      use_baked_mythic:            true  # after baking mythic"
    bold "      use_baked_sliver:            true  # after baking sliver"
    bold "      use_baked_win_server_2025:   true  # after baking server-2025"
    bold "      use_baked_win_server_2022:   true  # after baking server-2022"
    bold "      use_baked_win_server_2019:   true  # after baking server-2019"
    bold "      use_baked_win_10:            true  # after baking win-10"
    bold "      use_baked_win_11:            true  # after baking win-11"
    bold "      use_baked_elk:               true  # after baking elk"
    bold "      use_baked_redelk:            true  # after baking redelk"
    bold "      use_baked_debian_redirector: true  # after baking debian-redirector"
    bold "      use_baked_ghostwriter:       true  # after baking ghostwriter"
    bold "      use_baked_stepping_stones:   true  # after baking stepping-stones"
    bold ""
    bold "\`enabled\` alone just creates the (empty) gallery — use_baked_*"
    bold "is what switches deploys from Marketplace to the SIG image."
    bold "They're separate on purpose: the version lookup ERRORS the"
    bold "apply if you point at it before a version exists."
    bold ""
    bold "Time savings per deploy (Marketplace → baked):"
    bold "  kali              ~30 min → ~2-3 min   (biggest single win)"
    bold "  elk               ~20 min → ~3-5 min   (Elastic 8 + Kibana + agents pre-staged)"
    bold "  mythic            ~15 min → ~3-5 min   (docker + Go + mythic-cli built + images pre-pulled)"
    bold "  win-server-2022   ~15 min → ~3-5 min   (DC + AD-DS pre-installed)"
    bold "  win-server-2025   ~15 min → ~3-5 min   (DC-eligible, AD-DS pre-installed)"
    bold "  redelk            ~12 min → ~2-3 min   (docker + RedELK images pre-pulled)"
    bold "  adaptix           ~12 min → ~2-3 min   (Go + AdaptixC2 cloned + make pre-compiled)"
    bold "  win-server-2019   ~10 min → ~3-5 min   (member-server tier)"
    bold "  win-10 / win-11   ~10 min → ~3-5 min   (workstation tier)"
    bold "  guacamole         ~8 min → ~3-5 min    (docker + guac images + nginx + certbot)"
    bold "  debian-redirector  ~5 min → ~1-2 min   (per-redirector, multiplied"
    bold "                                          by per-student in shared mode)"
    bold "  sliver            ~3 min → ~30 sec    (sliver-server binary pre-downloaded)"
    bold ""
    bold "  brc4              ~5 min → ~5 min     (NOT baked: BRC4 binary is license-gated"
    bold "                                          per deploy via operator's Azure Blob SAS;"
    bold "                                          can't pre-stage the binary at image time)"
    bold ""
    bold "Re-bake any time: ./range bake <target> publishes a fresh version"
    bold "(terraform always picks the 'latest' version from the gallery)."
    ;;

  accept-marketplace|accept-mp)
    # Bulk-accept Marketplace terms for every published SKU under every
    # (publisher, offer) pair referenced by images.tf. Runs once per
    # subscription. Idempotent — re-running just re-accepts everything,
    # which is fine. Driven entirely from images.tf so adding a new OS
    # there automatically extends the bulk accept.
    #
    # Pass --update-images to also rewrite modules/azure/images.tf in
    # place so each os entry's `sku =` line points at the freshest SKU
    # discovered in Marketplace. Use this when an upstream image rolls
    # over (e.g. kali-2024-4 → kali-2026, win11-23h2-pro → win11-25h2-pro)
    # and you don't want to hand-edit images.tf.
    command -v az >/dev/null 2>&1 || die "az CLI required"
    update_images=0
    region="southeastasia"
    for arg in "$@"; do
      case "$arg" in
        --update-images|--bump) update_images=1 ;;
        --*) die "unknown flag for accept-marketplace: $arg" ;;
        *)   region="$arg" ;;
      esac
    done

    # Build unique (publisher, offer) pairs from images.tf.
    declare -a pairs=()
    while IFS= read -r line; do
      [[ -n "$line" ]] && pairs+=("$line")
    done < <(_dump_image_map | awk -F'|' '{print $2"|"$3}' | sort -u)

    if [[ "${#pairs[@]}" -eq 0 ]]; then
      die "no publisher/offer pairs parsed from modules/azure/images.tf"
    fi

    # Build pub|offer -> existing-SKU lookup BEFORE the loop; needed
    # for shape-matched "latest stable" filtering inside the loop.
    # Multi-line "<os>|<pub>|<offer>|<sku>" string + awk lookup so this
    # works on bash 3.2 (no associative arrays).
    image_map_dump=$(_dump_image_map)

    # Same UNSTABLE substring blocklist as the Python picker, evaluated
    # in shell. Used purely for OUTPUT marking — accepted-stable SKUs
    # get [+], accepted-unstable get [~] so the operator can see at a
    # glance which SKUs are pin candidates vs noise. Acceptance itself
    # still happens for ALL published SKUs (idempotent + harmless).
    UNSTABLE_RE='(^|[-_])(daily|nightly|preview|insider|canary|beta|alpha|rc|edge|test|rolling|snapshot|experimental|unstable|next|pre|cpc|arm|arm64|riscv|riscv64|fips|confidential)([-_]|$)'

    bold "Bulk-accepting Marketplace terms (region: $region)"
    echo "  Covering ${#pairs[@]} publisher/offer pair(s) from images.tf"
    echo "  Markers: [+] accepted (stable / pin candidate)"
    echo "           [~] accepted (unstable: daily/preview/arm64/fips/etc — not pinned)"
    echo "           [.] no terms required   [!] failed"
    echo
    total_accepted=0
    total_unstable=0
    total_skipped=0
    total_failed=0
    declare -a latest_skus=()

    for pair in "${pairs[@]}"; do
      IFS='|' read -r pub offer <<<"$pair"
      bold "$pub:$offer"
      skus=$(az vm image list --location "$region" \
        --publisher "$pub" --offer "$offer" --all \
        --query "[].sku" -o tsv 2>/dev/null | sort -u)
      if [[ -z "$skus" ]]; then
        warn "  no SKUs published in $region; skipping"
        echo
        continue
      fi
      while IFS= read -r sku; do
        [[ -z "$sku" ]] && continue
        # Decide stable-vs-unstable BEFORE accepting so we can mark
        # the output line accordingly. Acceptance is unconditional.
        if echo "$sku" | grep -qiE "$UNSTABLE_RE"; then
          marker="[~]"
          is_stable=0
        else
          marker="[+]"
          is_stable=1
        fi
        out=$(az vm image terms accept --publisher "$pub" --offer "$offer" \
          --plan "$sku" 2>&1) || true
        if [[ "$out" == *'"accepted": true'* ]]; then
          printf "  %s %s\n" "$marker" "$sku"
          if [[ "$is_stable" -eq 1 ]]; then
            total_accepted=$((total_accepted + 1))
          else
            total_unstable=$((total_unstable + 1))
          fi
        elif [[ "$out" == *"no terms"* ]] || [[ "$out" == *"has no terms"* ]]; then
          printf "  [.] %s (no terms required)\n" "$sku"
          total_skipped=$((total_skipped + 1))
        else
