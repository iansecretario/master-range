  bold "  [auto-bake] All required images baked. Proceeding to full apply."
  echo
}

# Auto-recover known-fragile failure modes via az run-command. Called
# automatically by `./range apply` after terraform succeeds (gated by
# `--no-repair`), and also exposed as `./range repair` for ad-hoc runs.
#
# Idempotent: every fix script no-ops when the target state is
# already good (e.g., nginx already active -> dpkg --configure does
# nothing, systemctl restart is fast).
#
# Assumes CWD is $ENV_DIR (so `terraform show -json` works).
_do_repair() {
  command -v az >/dev/null 2>&1 || { warn "az CLI not on PATH; skipping repair"; return 0; }
  command -v terraform >/dev/null 2>&1 || return 0
  [[ -d .terraform ]] || terraform init >/dev/null

  local vms_json
  vms_json=$(python3 - <<'PY'
import json, subprocess
r = subprocess.run(["terraform","show","-json"], capture_output=True, text=True, check=False)
try:
    state = json.loads(r.stdout)
except Exception:
    print("[]"); raise SystemExit(0)
vms = []
def walk(node):
    if not isinstance(node, dict): return
    if node.get("type") in ("azurerm_linux_virtual_machine","azurerm_windows_virtual_machine"):
        v = node.get("values", {}) or {}
        tags = v.get("tags") or {}
        vms.append({"name": v.get("name",""), "rg": v.get("resource_group_name",""), "role": tags.get("Role","")})
    for x in node.values():
        if isinstance(x, dict): walk(x)
        elif isinstance(x, list):
            for y in x: walk(y)
walk(state)
print(json.dumps(vms))
PY
  )

  # Repair scripts written to temp files so we don't have to wrestle
  # shell-special chars through Python string literals.
  local fix_dir
  fix_dir=$(mktemp -d -t range-repair.XXXXXX)

  cat > "$fix_dir/redir.sh" <<'REDIR_FIX'
set -x
sudo mkdir -p /etc/nginx/tls
if [ ! -f /etc/nginx/tls/cert.pem ]; then
  sudo openssl req -x509 -newkey rsa:2048 -nodes -days 825 \
    -keyout /etc/nginx/tls/key.pem \
    -out   /etc/nginx/tls/cert.pem \
    -subj /CN=redir
  sudo chmod 600 /etc/nginx/tls/key.pem
fi
# 1) Fix the alphabetical-load-order bug.
if [ -f /etc/nginx/conf.d/redelk-log-format.conf ] && [ ! -f /etc/nginx/conf.d/00-redelk-log-format.conf ]; then
  sudo mv /etc/nginx/conf.d/redelk-log-format.conf /etc/nginx/conf.d/00-redelk-log-format.conf
fi
# 2) Remove the Debian default site so it can't shadow our config.
#    Some configs ship a `listen 443 ssl default_server` in there too.
sudo rm -f /etc/nginx/sites-enabled/default
sudo rm -f /etc/nginx/sites-available/default
# 3) Remove any other default conf.d files that nginx packages drop.
sudo rm -f /etc/nginx/conf.d/default.conf
# 4) Validate + restart.
sudo dpkg --configure -a 2>&1 | tail -5
echo "--- conf.d after cleanup ---"
ls -la /etc/nginx/conf.d/
echo "--- nginx -t ---"
sudo nginx -t 2>&1 || { echo "nginx -t FAILED — dumping conf.d:"; ls -la /etc/nginx/conf.d/; exit 1; }
sudo systemctl restart nginx
echo "--- listening (should show :443) ---"
sudo ss -lntp | grep nginx
echo "--- final state ---"
sudo systemctl is-active nginx
# 5) Smoke test: hit our server WITHOUT the auth header, expect 302 to
#    cover_url. If we get the Debian welcome page (200 'Welcome to
#    nginx!'), our config isn't being loaded.
echo "--- smoke test (no auth header -> should be 302) ---"
curl -sk -o /dev/null -w "HTTPS without auth header: HTTP %{http_code} -> %{redirect_url}\n" https://127.0.0.1/ || true

echo
echo "============ REDIRECTOR DIAGNOSTIC DUMP ============"
echo "--- nginx config files (full list) ---"
sudo ls -la /etc/nginx/conf.d/ /etc/nginx/sites-enabled/ 2>&1
echo
echo "--- nginx error.log tail ---"
sudo tail -20 /var/log/nginx/error.log 2>&1 || true
echo
echo "--- access-redelk.log tail (showing recent beacon traffic if any) ---"
sudo tail -10 /var/log/nginx/access-redelk.log 2>&1 || echo "(no traffic yet)"
echo
echo "--- listening on :443 ---"
sudo ss -lntp 2>/dev/null | grep ':443[[:space:]]'
echo "============ END DUMP ============"
REDIR_FIX

  cat > "$fix_dir/adaptix.sh" <<'ADAPTIX_FIX'
# NOTE: deliberately NO `set -x` here. The repair invoker caps each VM's
# RunCommand output at ~32k chars; `set -x` doubles every line (once as
# bash trace in [stderr], once as command output in [stdout]) and
# blows that budget before the DIAGNOSTIC DUMP can emit the adaptix
# journal — which is exactly the data we need to see why listeners
# don't register. Targeted `echo "[+] ..."` markers instead.
set -e
LOG=/var/log/adaptix-build.log
export PATH=/usr/local/go/bin:/usr/local/bin:$PATH
# Adaptix's Makefile sets GOEXPERIMENT=jsonv2 which is only recognised
# by Go 1.25+. With 1.22.7 the build dies with:
#   go: unknown GOEXPERIMENT jsonv2
#   make: *** [Makefile:70: server] Error 1
# Bumping to 1.25.4 also matches what the plugin .so files were built
# with on first-boot (we'd previously seen go1.25.4 in plugins), so
# the server/plugin Go versions align naturally.
GO_VER=1.25.4
# Go 1.21+ honors the `toolchain` directive in go.mod and SILENTLY
# downloads a newer Go (e.g. go1.25.4) to $HOME/sdk/, then builds with
# it instead of our pinned /usr/local/go. That's why the previous
# repair's DIAGNOSTIC DUMP showed both server AND plugins as go1.25.4
# even though /usr/local/go is 1.22.7. Force the pinned local toolchain.
export GOTOOLCHAIN=local

# ---------- Phase 1: install pinned Go (always — don't trust pre-existing) ----------
# Go plugin ABI is version-locked: server binary and .so plugins MUST
# be built with the SAME Go version, or dlopen fails silently and the
# server starts without any extender registered ("listener BeaconHTTP
# does not register"). We always reinstall our pinned 1.22.7 to make
# certain server + plugins agree.
if ! /usr/local/go/bin/go version 2>/dev/null | grep -q "$GO_VER"; then
  sudo curl -fsSL "https://go.dev/dl/go${GO_VER}.linux-amd64.tar.gz" -o /tmp/go.tgz
  sudo rm -rf /usr/local/go && sudo tar -C /usr/local -xzf /tmp/go.tgz
  sudo ln -sf /usr/local/go/bin/go /usr/local/bin/go
  sudo ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt
fi
/usr/local/go/bin/go version | sudo tee -a "$LOG"

cd /opt/adaptix/AdaptixC2 || { echo "AdaptixC2 dir missing — repo never cloned"; exit 1; }

# ---------- Phase 1b: check Go version mismatch between server and plugins ----------
# Parse Go version embedded in the server binary; if it differs from
# our pinned $GO_VER, force a clean rebuild of EVERYTHING.
if [ -x dist/adaptixserver ]; then
  SERVER_GO=$(sudo strings dist/adaptixserver 2>/dev/null \
                | grep -oE '^go1\.[0-9]+(\.[0-9]+)?$' | head -n1)
  echo "[i] adaptixserver was built with: ${SERVER_GO:-unknown}"
  if [ -n "$SERVER_GO" ] && [ "$SERVER_GO" != "go${GO_VER}" ]; then
    echo "[!] Go version mismatch (server=$SERVER_GO vs pinned=go${GO_VER}) — clean rebuild"
    sudo rm -f dist/adaptixserver
    sudo rm -f AdaptixServer/extenders/*/*.so
  fi
fi

# ---------- Phase 2: ensure BOTH server binary AND extender .so plugins ----------
# Earlier runs of `make server-ext` produced the server binary but no
# .so files. Without the .so plugins the teamserver answers /login
# but rejects /listener/create with
#   "listener BeaconHTTP does not register"
# because the BeaconHTTP type was never registered at server boot.
#
# DO NOT run `make all` here. The upstream Adaptix Makefile's `all`
# target builds three things: server, plugins, and the GUI client.
# The GUI client uses CMake and requires CMake >= 3.28. Ubuntu 22.04
# ships CMake 3.25, so `make all` ALWAYS dies with:
#   [ERROR] CMake failed: CMake 3.28 or higher is required.
#   make: *** [Makefile:83: client] Error 1
# That non-zero exit then prevents `make ext` from running and confuses
# the per-plugin fallback. We do not need the client on the teamserver
# VM (operators run it from Kali), so skip it entirely.
#
# sudo strips PATH (via /etc/sudoers' secure_path) AND HOME, both of
# which Go needs (PATH for go binary, HOME for module cache location).
# Use `sudo env` with explicit env list to preserve both.
SUDO_ENV='sudo env PATH=/usr/local/go/bin:'$PATH' HOME=/root GOPATH=/root/go GOMODCACHE=/root/go/pkg/mod GOCACHE=/root/.cache/go-build GOTOOLCHAIN=local'
$SUDO_ENV make server 2>&1 | sudo tee -a "$LOG" | tail -8 || true
# `make ext` may not exist as a target on all Adaptix versions; the
# per-plugin fallback below covers the case where it doesn't.
$SUDO_ENV make ext 2>&1 | sudo tee -a "$LOG" | tail -8 || true

# If `make all`/`ext` didn't produce plugins (the upstream Makefile
# may not have an `ext` target at all), build each extender directly
# with go's buildmode=plugin.
#
# CRITICAL: the .so filename must match what each extender's
# config.yaml declares in its `extender_file:` field. The convention
# is NOT just "<dirname>.so" — it's a swapped form e.g.:
#   directory beacon_listener_http/  ->  listener_beacon_http.so
#   directory beacon_listener_smb/   ->  listener_beacon_smb.so
#   directory gopher_listener_tcp/   ->  listener_gopher_tcp.so
#   directory beacon_agent/          ->  agent_beacon.so
# adaptixserver looks up the .so by the config.yaml's name, so
# building "<dirname>.so" produces an orphan file that the server
# can't find, surfacing as "listener BeaconHTTP does not register".
for d in /opt/adaptix/AdaptixC2/AdaptixServer/extenders/*/; do
  base=$(basename "$d")
  expected_so=$(grep -E '^extender_file:' "$d/config.yaml" 2>/dev/null \
                  | sed -E 's/^extender_file:[[:space:]]*"([^"]+)".*/\1/' \
                  | head -n1)
  if [ -z "$expected_so" ]; then
    expected_so="$base.so"
    echo "[!] $base has no extender_file in config.yaml; falling back to $expected_so"
  fi
  # Clean up wrongly-named .so from earlier runs
  if [ -f "$d/$base.so" ] && [ "$base.so" != "$expected_so" ]; then
    echo "[~] removing orphan $base.so (server expects $expected_so)"
    sudo rm -f "$d/$base.so"
  fi
  if [ ! -f "$d/$expected_so" ]; then
    echo "[+] building $expected_so..."
    # Same env preservation as the server build — Go needs HOME for
    # the module cache.
    (cd "$d" && sudo env \
        PATH="/usr/local/go/bin:$PATH" \
        HOME="/root" \
        GOPATH="/root/go" \
        GOMODCACHE="/root/go/pkg/mod" \
        GOCACHE="/root/.cache/go-build" \
        GOTOOLCHAIN="local" \
        /usr/local/go/bin/go build -buildmode=plugin -o "$expected_so" .) \
      2>&1 | sudo tee -a "$LOG" | tail -10
  else
    echo "[=] $expected_so already present"
  fi
done

echo "--- extender .so inventory (after rename) ---"
ls -la /opt/adaptix/AdaptixC2/AdaptixServer/extenders/*/*.so 2>&1 | sudo tee -a "$LOG"

# ---------- Phase 2b: forcibly rebuild server with PINNED Go ----------
# `make server` knows the exact `cd AdaptixServer && go build` dance —
# we just need to feed it the right env. Two things sudo strips:
#   - PATH (via /etc/sudoers' secure_path): need PATH=/usr/local/go/bin first
#   - HOME: need HOME=/root so Go can find/create its module cache
#           (GOPATH=$HOME/go by default). Without HOME, build dies with
#           "module cache not found: neither GOMODCACHE nor GOPATH is set".
echo "[+] forcibly rebuilding server with pinned Go via 'make server' (HOME + PATH preserved)"
cd /opt/adaptix/AdaptixC2
sudo rm -f dist/adaptixserver
sudo env \
    PATH="/usr/local/go/bin:$PATH" \
    HOME="/root" \
    GOPATH="/root/go" \
    GOMODCACHE="/root/go/pkg/mod" \
    GOCACHE="/root/.cache/go-build" \
    make server 2>&1 | sudo tee -a "$LOG" | tail -25

if ! [ -x /opt/adaptix/AdaptixC2/dist/adaptixserver ]; then
  echo "[!] 'make server' failed — trying direct go build as fallback"
  # Direct build from the AdaptixServer directory (where go.mod lives).
  if [ -d AdaptixServer ] && [ -f AdaptixServer/go.mod ]; then
    sudo env \
        PATH="/usr/local/go/bin:$PATH" \
        HOME="/root" \
        GOPATH="/root/go" \
        GOMODCACHE="/root/go/pkg/mod" \
        GOCACHE="/root/.cache/go-build" \
        GOTOOLCHAIN="local" \
        bash -c 'cd AdaptixServer && /usr/local/go/bin/go build -o ../dist/adaptixserver .' \
        2>&1 | sudo tee -a "$LOG" | tail -20
  fi
fi

if ! [ -x /opt/adaptix/AdaptixC2/dist/adaptixserver ]; then
  echo "BUILD STILL FAILING — last 40 lines of build log:"
  sudo tail -40 "$LOG"
  exit 1
fi

# ---------- Phase 2c: VERIFY server and plugin Go versions match ----------
# Read the FIRST plugin's actual filename from its config.yaml (post-rename)
# instead of hardcoding — the rename convention swaps dirname parts.
FIRST_DIR=/opt/adaptix/AdaptixC2/AdaptixServer/extenders/beacon_listener_http
FIRST_SO_NAME=$(grep -E '^extender_file:' "$FIRST_DIR/config.yaml" 2>/dev/null \
                  | sed -E 's/^extender_file:[[:space:]]*"([^"]+)".*/\1/' | head -n1)
FIRST_SO="$FIRST_DIR/${FIRST_SO_NAME:-listener_beacon_http.so}"

SERVER_GO=$(sudo strings /opt/adaptix/AdaptixC2/dist/adaptixserver 2>/dev/null \
              | grep -oE '^go1\.[0-9]+(\.[0-9]+)?$' | sort -u | head -n1)
PLUGIN_GO=$(sudo strings "$FIRST_SO" 2>/dev/null \
              | grep -oE '^go1\.[0-9]+(\.[0-9]+)?$' | sort -u | head -n1)
echo "[=] server built with: ${SERVER_GO:-unknown}"
echo "[=] plugin built with: ${PLUGIN_GO:-unknown}  ($FIRST_SO_NAME)"

if [ -z "$SERVER_GO" ] || [ -z "$PLUGIN_GO" ]; then
  echo "[!] couldn't extract Go version from binary — strings may be stripped"
elif [ "$SERVER_GO" != "$PLUGIN_GO" ]; then
  echo "[!] MISMATCH STILL — server=$SERVER_GO plugin=$PLUGIN_GO. Rebuilding plugins too."
  for d in /opt/adaptix/AdaptixC2/AdaptixServer/extenders/*/; do
    base=$(basename "$d")
    expected_so=$(grep -E '^extender_file:' "$d/config.yaml" 2>/dev/null \
                    | sed -E 's/^extender_file:[[:space:]]*"([^"]+)".*/\1/' | head -n1)
    [ -z "$expected_so" ] && expected_so="$base.so"
    sudo rm -f "$d/$expected_so"
    (cd "$d" && sudo env \
        PATH="/usr/local/go/bin:$PATH" \
        HOME="/root" \
        GOPATH="/root/go" \
        GOMODCACHE="/root/go/pkg/mod" \
        GOCACHE="/root/.cache/go-build" \
        GOTOOLCHAIN="local" \
        /usr/local/go/bin/go build -buildmode=plugin -o "$expected_so" .) 2>&1 \
      | sudo tee -a "$LOG" | tail -5
  done
else
  echo "[+] Go versions MATCH — plugins will dlopen cleanly"
fi

# ---------- Phase 3: restart adaptix to load new extenders ----------
sudo systemctl daemon-reload
sudo systemctl restart adaptix
sleep 10
sudo systemctl is-active adaptix || true

# ---------- Phase 4: register the 5 listeners ----------
# `systemctl restart adaptix-listeners` would BLOCK until the unit's
# ExecStart completes — and the oneshot script (configure_listeners.py)
# polls /login for up to 600s before giving up. That hang was eating
# the whole 900s outer RunCommand budget and preventing the diagnostic
# dump from ever running. --no-block returns immediately; we then
# poll the unit's state for a short window so the dump still has
# fresh data to show.
echo "[+] kicking adaptix-listeners (non-blocking)"
sudo systemctl reset-failed adaptix-listeners 2>/dev/null || true
sudo systemctl restart --no-block adaptix-listeners || true
# Disable set -e from here on so the dump section ALWAYS runs, even
# if one of its commands exits non-zero (e.g., journalctl with no
# matching unit, ss not installed in some minimal image, etc.).
set +e
# Poll up to 90s for either listeners coming up OR adaptix-listeners
# unit settling to active/failed (so the .log has fresh content).
for i in 1 2 3 4 5 6 7 8 9; do
  sleep 10
  listener_count=$(sudo ss -lntp 2>/dev/null | grep -cE ':844[3-7]\b')
  unit_state=$(sudo systemctl is-active adaptix-listeners 2>/dev/null || true)
  [ "$listener_count" -ge 5 ] && break
  [ "$unit_state" = "failed" ] && break
done
listener_count=$(sudo ss -lntp 2>/dev/null | grep -cE ':844[3-7]\b')
echo "[=] listener ports active: $listener_count/5  (adaptix-listeners.service: ${unit_state:-unknown})"

# --- ALWAYS dump diagnostics, regardless of success/failure, so the
# --- operator never needs to SSH in to see what happened.
# IMPORTANT — ORDERING: the per-VM RunCommand output is capped (32k
# chars). The data we ACTUALLY need to diagnose "operator :9000 up,
# but listeners :8443-8447 missing" is:
#   1. adaptix-listeners.log (configure_listeners.py output — shows
#      whether /listener/create returned 200, 400, 404, etc., and the
#      response body. THIS IS THE SMOKING GUN.)
#   2. adaptix journal — any "plugin was built with go..." panic or
#      "type not found" rejection.
#   3. listener_count summary.
# Put these THREE FIRST so they're guaranteed to fit. Build logs and
# per-plugin Go-version listings come LAST.
echo
echo "============ ADAPTIX DIAGNOSTIC DUMP ============"
# IMPORTANT — KEEP THIS DUMP SMALL (target: under ~3000 chars total).
# Azure RunCommand has a buffered message field that DROPS THE FRONT
# of stdout when output exceeds the buffer. A previous version of this
# dump emitted ~40 lines of /opt/adaptix/listeners.json and pushed the
# top sections (which are exactly what we need to see — adaptix-listeners.log
# and the /login probe response) off the front of the message. Pulled
# listeners.json + journal + Go-version walk into ONE-LINER summaries
# so the critical signals always survive.
echo "--- adaptix-listeners.log (last 25) — HTTP responses from /listener/create ---"
sudo tail -25 /var/log/adaptix-listeners.log 2>&1 | tail -25 || echo "(no adaptix-listeners.log)"
echo
echo "--- /login probe ---"
LIVE_USER=$(sudo grep -E '^Environment=ADAPTIX_USER=' /etc/systemd/system/adaptix-listeners.service 2>/dev/null | head -1 | sed 's/^[^=]*=[^=]*=//')
LIVE_PASS=$(sudo grep -E '^Environment=ADAPTIX_PASS=' /etc/systemd/system/adaptix-listeners.service 2>/dev/null | head -1 | sed 's/^[^=]*=[^=]*=//')
echo "    user=${LIVE_USER:-<unset>} pass=$( [ -n "$LIVE_PASS" ] && echo '<set>' || echo '<UNSET!>' )"
curl -sk -X POST "https://127.0.0.1:9000/endpoint/login" \
  -H "Content-Type: application/json" --max-time 8 \
  -w "    -> HTTP %{http_code}\n" \
  -d "{\"username\":\"${LIVE_USER}\",\"password\":\"${LIVE_PASS}\"}" 2>&1 | tail -3
echo
echo "--- adaptix journal: errors/panics/plugin-load (filtered, last 30) ---"
sudo journalctl -u adaptix --no-pager -n 200 2>&1 \
  | grep -iE 'plugin|extender|register|panic|error|fail|listener' \
  | tail -30
echo
echo "--- systemd state + listening ports ---"
sudo systemctl is-active adaptix adaptix-listeners 2>&1 | tr '\n' ' '; echo
sudo ss -lntp 2>/dev/null | grep -E ':(9000|844[3-7])\b' | awk '{print "  " $0}'
echo
echo "--- versions (server vs plugin) ---"
SRV_GO=$(sudo strings /opt/adaptix/AdaptixC2/dist/adaptixserver 2>/dev/null | grep -oE '^go1\.[0-9]+(\.[0-9]+)?$' | sort -u | head -1)
PL_GO=$(sudo strings /opt/adaptix/AdaptixC2/AdaptixServer/extenders/beacon_listener_http/listener_beacon_http.so 2>/dev/null | grep -oE '^go1\.[0-9]+(\.[0-9]+)?$' | sort -u | head -1)
echo "  server=${SRV_GO:-stripped}  plugin(beacon_listener_http)=${PL_GO:-stripped}"
ls /opt/adaptix/AdaptixC2/AdaptixServer/extenders/*/*.so 2>/dev/null | xargs -n1 basename | sort | tr '\n' ' '; echo
echo
echo "--- build log tail (last 8 — confirms which target failed) ---"
sudo tail -8 /var/log/adaptix-build.log 2>&1 | tail -8 || true
sudo tail -25 /var/log/adaptix-build.log 2>&1 || true
echo "============ END DUMP ============"
ADAPTIX_FIX

  cat > "$fix_dir/guac.sh" <<'GUAC_FIX'
set -x
# Re-run register.py so Guacamole connection params (notably the RDP
# passwords) get refreshed from the current manifest. The script is
# now upsert-aware, so existing connections get their stale passwords
# overwritten. Required after any rotation of random_password.* values
# (which terraform does whenever the resource's lifecycle ignore_changes
# triggers a regen).
if [ ! -f /opt/guac/register.py ]; then
  echo "[!] /opt/guac/register.py missing; Guacamole bootstrap didn't run"
  exit 1
fi
sudo python3 /opt/guac/register.py 2>&1 | tail -50
echo "--- connection count ---"
sudo docker exec "$(sudo docker ps -qf name=postgres | head -n1)" \
  psql -U guacamole_user -d guacamole_db -tAc "SELECT COUNT(*) FROM guacamole_connection" 2>/dev/null

echo
echo "============ GUACAMOLE DIAGNOSTIC DUMP ============"
echo "--- docker stack ---"
sudo docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>&1 | head
echo
echo "--- guac-register.log tail ---"
sudo tail -30 /var/log/guac-register.log 2>&1 || true
echo
echo "--- LE cert status ---"
sudo openssl x509 -in /opt/guac/tls/cert.pem -noout -subject -issuer -dates 2>&1 | head -5
echo
echo "--- guacamole-letsencrypt.log tail ---"
sudo tail -15 /var/log/guacamole-letsencrypt.log 2>&1 || echo "(no LE log yet)"
