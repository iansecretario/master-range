PORTS="__PORTS__"
LISTEN_RAW=$(sudo ss -lntp 2>/dev/null)
for port in $PORTS; do
    line=$(echo "$LISTEN_RAW" | grep -E ":$port[[:space:]]" | head -n1)
    if [ -n "$line" ]; then
        proc=$(echo "$line" | sed -E 's/.*users:\(\("([^"]+)",pid=([0-9]+).*/\1|\2/' | head -n1)
        if [ -z "$proc" ] || [ "$proc" = "$line" ]; then proc="unknown|?"; fi
        echo "$port|UP|$proc"
    else
        echo "$port|MISSING|-|-"
    fi
done
PROBE

  echo "$vms_json" | FIX_DIR="$fix_dir" python3 -c "
import sys, json, subprocess, os, time
from concurrent.futures import ThreadPoolExecutor, as_completed
vms = json.load(sys.stdin)
tpl = open(os.path.join(os.environ['FIX_DIR'], 'listener-probe.sh')).read()

def wait_idle(rg, name, max_wait_s=120):
    deadline = time.time() + max_wait_s
    while time.time() < deadline:
        r = subprocess.run([
            'az','vm','run-command','list',
            '-g', rg, '--vm-name', name, '-o','json',
        ], capture_output=True, text=True, timeout=60)
        if r.returncode != 0:
            return True
        try:
            cmds = json.loads(r.stdout or '[]')
        except Exception:
            return True
        busy = [c.get('name','?') for c in (cmds or [])
                if (c.get('provisioningState') or '').lower()
                   in ('creating','updating','running','provisioning')]
        if not busy:
            return True
        time.sleep(30)
    return False

def probe_with_retry(rg, name, probe, max_attempts=6):
    # Reduced from 20 to 6 retries because:
    #   - the WHOLE _do_repair pass is already wrapped in a 3-attempt
    #     retry loop in _do_repair_with_retry, which gives extra
    #     opportunities for transient Conflict to clear.
    #   - probes now run IN PARALLEL across VMs, so a stuck Sliver
    #     no longer holds up the others. Better to declare it
    #     PROBE FAILED quickly and let the next outer attempt re-try.
    wait_idle(rg, name)
    for attempt in range(1, max_attempts + 1):
        r = subprocess.run([
            'az','vm','run-command','invoke',
            '-g', rg, '-n', name,
            '--command-id','RunShellScript',
            '--scripts', probe,
            '--query','value[0].message',
            '-o','tsv',
        ], capture_output=True, text=True, timeout=120)
        if r.returncode == 0:
            return r
        if 'Conflict' in (r.stderr or '') and 'in progress' in (r.stderr or ''):
            time.sleep(min(45, 10 + 5 * attempt))
            continue
        return r
    return r

ROLE_PORTS = {
    'c2-server':     [('9000',  'commander (operator)'),
                      ('8443',  'HTTPS listener (azure CDN)'),
                      ('8444',  'HTTPS listener (cloudfront)'),
                      ('8445',  'HTTPS listener (workers)'),
                      ('8446',  'HTTPS listener (fastly)'),
                      ('8447',  'HTTPS listener (other)')],
    'c2-mythic':     [('7443',  'web UI / GraphQL (operator)'),
                      ('8443',  'httpx listener (azure CDN)'),
                      ('8444',  'httpx listener (cloudfront)'),
                      ('8445',  'httpx listener (workers)'),
                      ('8446',  'httpx listener (fastly)'),
                      ('8447',  'httpx listener (other)')],
    'c2-brc4':       [('9000',  'commander (operator)'),
                      ('8443',  'HTTPS listener (azure CDN)'),
                      ('8444',  'HTTPS listener (cloudfront)'),
                      ('8445',  'HTTPS listener (workers)'),
                      ('8446',  'HTTPS listener (fastly)'),
                      ('8447',  'HTTPS listener (other)')],
    'c2-sliver':     [('31337', 'multiplayer gRPC (operator)'),
                      ('8443',  'HTTPS listener (azure CDN)'),
                      ('8444',  'HTTPS listener (cloudfront)'),
                      ('8445',  'HTTPS listener (workers)'),
                      ('8446',  'HTTPS listener (fastly)'),
                      ('8447',  'HTTPS listener (other)')],
    'c2-redirector': [('443',   'HTTPS (CDN -> redirector)')],
}
# Build the in-scope probe targets.
probe_targets = [v for v in vms if v['role'] in ROLE_PORTS]

def probe_one(v):
    # Returns (name, role, lines[]) so the main thread can print
    # everything in stable name-sorted order without interleaving.
    role = v['role']
    expected = ROLE_PORTS[role]
    port_list = ' '.join(p for p,_ in expected)
    probe = tpl.replace('__PORTS__', port_list)
    lines = []
    lines.append('------ {0}  ({1}) ------'.format(v['name'], role))
    try:
        r = probe_with_retry(v['rg'], v['name'], probe)
    except subprocess.TimeoutExpired:
        lines.append('  TIMEOUT — VM unreachable')
        return v['name'], role, lines
    if r.returncode != 0:
        lines.append('  PROBE FAILED: ' + (r.stderr or '')[:300])
        return v['name'], role, lines
    out = (r.stdout or '').strip()
    if not out:
        lines.append('  (empty response)')
        return v['name'], role, lines
    states = {}
    for line in out.splitlines():
        parts = line.strip().split('|')
        if len(parts) >= 2 and parts[0].isdigit():
            states[parts[0]] = parts[1:]
    up = 0
    for port, label in expected:
        info = states.get(port)
        if info and info[0] == 'UP':
            proc = info[1] if len(info) > 1 else '?'
            pid  = info[2] if len(info) > 2 else '?'
            lines.append('  [OK]      :{0:<6}  {1:<34} ({2} pid={3})'.format(port, label, proc, pid))
            up += 1
        else:
            lines.append('  [MISSING] :{0:<6}  {1:<34} NOT LISTENING'.format(port, label))
    lines.append('  -> {0}/{1} expected ports up'.format(up, len(expected)))
    return v['name'], role, lines

# PARALLEL probes. Same rationale as the repair invokes: each call is
# a separate az CLI round-trip waiting on the VM agent; serializing
# them just adds up timeouts. ThreadPoolExecutor with 8 workers covers
# our largest scenarios.
results = {}
if probe_targets:
    with ThreadPoolExecutor(max_workers=min(8, len(probe_targets))) as pool:
        futs = {pool.submit(probe_one, v): v['name'] for v in probe_targets}
        for fut in as_completed(futs):
            try:
                n, role, lines = fut.result()
            except Exception as e:
                n = futs[fut]
                lines = ['------ {0} ------'.format(n), '  EXCEPTION: ' + str(e)]
            results[n] = lines

for name in sorted(results.keys()):
    print()
    for ln in results[name]:
        print(ln)
"

  rm -rf "$fix_dir"
}

# Wrapper that runs _do_repair up to N attempts, sleeping S seconds
# between, and stops early when no [MISSING] or PROBE FAILED lines
# remain in the transcript.
#
# Args:
#   $1  max attempts (default 3)
#   $2  seconds between attempts (default 90)
#
# Behavior:
#   - Tees per-attempt output to /tmp/range-repair-<stamp>-attempt-N.log
#   - Aggregates all attempts into /tmp/range-repair-<stamp>.log
#   - Sets the global $REPAIR_FINAL_STATUS to "ok" or "incomplete"
#     and $REPAIR_LOG_PATH so callers can reference them.
_do_repair_with_retry() {
  local max_attempts="${1:-3}"
  local wait_between="${2:-90}"
  local stamp
  stamp="$(date +%Y%m%d-%H%M%S)"
  REPAIR_LOG_PATH="/tmp/range-repair-${stamp}.log"
  REPAIR_FINAL_STATUS="incomplete"
  : > "$REPAIR_LOG_PATH"  # truncate / create

  bold "Repair plan: up to ${max_attempts} attempt(s), ${wait_between}s between"
  bold "Transcript:  $REPAIR_LOG_PATH"

  local attempt attempt_log missing_count probe_fail_count unhealthy
  for attempt in $(seq 1 "$max_attempts"); do
    echo
    bold "================================================================"
    bold "  REPAIR ATTEMPT $attempt / $max_attempts"
    bold "================================================================"
    attempt_log="/tmp/range-repair-${stamp}-attempt-${attempt}.log"
    { _do_repair; } 2>&1 | tee "$attempt_log" | tee -a "$REPAIR_LOG_PATH"

    # Count unresolved issues from this pass's transcript.
    #   [MISSING]    — a port that the LISTENER SUMMARY expected isn't listening
    #   PROBE FAILED — we couldn't even query the VM (e.g., Conflict)
    missing_count=$(grep -cE '^\s*\[MISSING\] '   "$attempt_log" 2>/dev/null || echo 0)
    probe_fail_count=$(grep -c 'PROBE FAILED'     "$attempt_log" 2>/dev/null || echo 0)
    # Strip any non-digits grep may have emitted (rare, defensive).
    missing_count=${missing_count//[^0-9]/}
    probe_fail_count=${probe_fail_count//[^0-9]/}
    missing_count=${missing_count:-0}
    probe_fail_count=${probe_fail_count:-0}
    unhealthy=$(( missing_count + probe_fail_count ))

    echo
    if [[ "$unhealthy" -eq 0 ]]; then
      bold "[+] attempt $attempt: all expected listeners UP (no [MISSING], no PROBE FAILED)"
      REPAIR_FINAL_STATUS="ok"
      break
    fi
    bold "[-] attempt $attempt: $missing_count missing port(s), $probe_fail_count probe failure(s)"

    if [[ "$attempt" -lt "$max_attempts" ]]; then
      bold "    sleeping ${wait_between}s before retry..."
      sleep "$wait_between"
    else
      bold "    out of attempts ($max_attempts)."
    fi
  done

  echo
  if [[ "$REPAIR_FINAL_STATUS" == "ok" ]]; then
    bold "Repair converged. Full transcript: $REPAIR_LOG_PATH"
  else
    warn "Repair did NOT fully converge after $max_attempts attempt(s)."
    warn "Inspect the dump:  cat $REPAIR_LOG_PATH"
    warn "Or try again:      ./range repair --retry 3 --wait 120"
  fi
}

# Post-apply configuration entry point used by `./range apply`.
# Prefers Ansible (modules/azure/ansible/playbook.yml) and falls back
# to the legacy az-run-command pass when ansible isn't installed. The
# fallback exists so a fresh checkout on a machine without ansible
# still finishes apply successfully -- just with the older, slower
# repair behavior. Once the operator installs ansible, every subsequent
# apply / repair uses it.
_post_apply_configure() {
  local ansible_dir stamp
  ansible_dir="$REPO/modules/azure/ansible"
  if [[ ! -d "$ansible_dir" ]]; then
    warn "ansible dir missing ($ansible_dir) — falling back to legacy repair"
    _do_repair_with_retry 3 90
    return
  fi
  if ! command -v ansible-playbook >/dev/null 2>&1; then
    warn "ansible-playbook not installed — falling back to legacy repair"
    warn "  install with: brew install ansible   (or pipx install ansible-core)"
    _do_repair_with_retry 3 90
    return
  fi

  # Delegate to the SAME from-guac path as `./range repair`: this Mac
  # SSHes to guacamole, and guac runs ansible against every target over
  # the hub<->spoke VNet peering. This is the ONLY path that reaches the
  # isolated attacker box (kali-xrdp) — it has no public IP and no
  # redirector to ProxyJump through, so the previous laptop-local
  # `ansible-playbook playbook.yml` here timed out on it on EVERY apply
  # (the kali play + every kali-targeted play came back UNREACHABLE).
  # Reusing the repair subcommand keeps a single tested from-guac
  # codepath for both `apply` and `repair` instead of two divergent
  # ansible flows. No infinite recursion: `repair` never calls back into
  # `_post_apply_configure` (that's apply-only).
  REPAIR_FINAL_STATUS="incomplete"
  bold "Configuring via Ansible (from-guac controller — same path as ./range repair)..."

  set +e
  TERRA_PROVIDER="$PROVIDER" "$REPO/range" repair "$@"
  local rc=$?
  set -e

  if [[ "$rc" -eq 0 ]]; then
    REPAIR_FINAL_STATUS="ok"
    bold "[+] Ansible converged (from-guac)."
  else
    REPAIR_FINAL_STATUS="incomplete"
    warn "Ansible repair exited rc=$rc."
    warn "  Re-run full:  ./range repair"
    warn "  Debug a role: ./range repair --limit <host> -v"
  fi
}

# Pre-flight checks before apply: az login, Marketplace terms, vCPU
# quota, cost estimate.
#   Returns 0 on success.
#   Returns non-zero on warnings (operator may continue regardless).
preflight_checks() {
  local yaml="$1"
  local fail=0

  if ! command -v az >/dev/null 2>&1; then
    warn "az CLI not on PATH — pre-flight checks skipped"
    return 0
  fi

  bold "Pre-flight checks"

  # 1. Azure auth.
  if ! az account show >/dev/null 2>&1; then
    warn "  [!] az account show failed — run 'az login' before applying"
    fail=1
  else
    sub=$(az account show --query name -o tsv 2>/dev/null)
    echo "  [+] az subscription: $sub"
  fi

  # 1b. DNS zone for advanced_c2 (AFD custom domains). If the scenario
  # references `advanced_c2.domain` + `dns_zone_resource_group`, the
  # zone must already exist — terraform's data "azurerm_dns_zone"
  # fails the apply with "zone was not found" and rolls back partial
  # AFD setup. Auto-create the RG + zone here when missing (cheap,
  # idempotent). NS delegation at the registrar is still manual and
  # MUST be done before AFD's cert validation polls — we print the
  # nameservers loudly so the operator can paste them into the
  # registrar's DNS panel.
  afd_region=$(grep -E '^azure_region:' "$yaml" | awk -F'[: ]+' '{print $2}' | tr -d '"' | head -1)
  afd_region="${afd_region:-southeastasia}"
  afd_domain=$(awk -F'[: ]+' '/^advanced_c2:/{f=1; next} f && /^[a-zA-Z_]+:/ && !/^  /{f=0} f && /^  domain:/{print $3; exit}' "$yaml" | tr -d '"')
  afd_dns_rg=$(awk -F'[: ]+' '/^advanced_c2:/{f=1; next} f && /^[a-zA-Z_]+:/ && !/^  /{f=0} f && /^  dns_zone_resource_group:/{print $3; exit}' "$yaml" | tr -d '"')
  afd_dns_sub=$(awk -F'[: ]+' '/^advanced_c2:/{f=1; next} f && /^[a-zA-Z_]+:/ && !/^  /{f=0} f && /^  dns_zone_subscription_id:/{print $3; exit}' "$yaml" | tr -d '"')
  # Cross-sub: pass --subscription to all DNS-zone az calls below so
  # we don't have to flip the operator's default subscription.
  dns_sub_args=""
  [[ -n "$afd_dns_sub" ]] && dns_sub_args="--subscription $afd_dns_sub"
  if [[ -n "$afd_domain" && -n "$afd_dns_rg" ]]; then
    if [[ -n "$afd_dns_sub" ]]; then
      echo "  [.] DNS zone is in cross-subscription: $afd_dns_sub"
    fi
    if az network dns zone show $dns_sub_args -g "$afd_dns_rg" -n "$afd_domain" >/dev/null 2>&1; then
      echo "  [+] Azure DNS zone exists: $afd_domain (rg: $afd_dns_rg)"
      ns=$(az network dns zone show $dns_sub_args -g "$afd_dns_rg" -n "$afd_domain" \
        --query "nameServers" -o tsv 2>/dev/null | tr '\t' '\n' | head -4)
      echo "      Nameservers (must be delegated at your registrar):"
      printf '        %s\n' $ns
    else
      warn "  [!] Azure DNS zone NOT found: $afd_domain in rg '$afd_dns_rg'"
      warn "      Auto-creating now (one-time, ~\$0.50/mo)..."
      # Create RG if missing.
      if ! az group show $dns_sub_args -n "$afd_dns_rg" >/dev/null 2>&1; then
        echo "      az group create $dns_sub_args -l $afd_region -n $afd_dns_rg"
        if ! az group create $dns_sub_args -l "$afd_region" -n "$afd_dns_rg" >/dev/null 2>&1; then
          warn "      [!] failed to create RG; create manually and re-run preflight"
          fail=1
        else
          echo "      [+] RG created: $afd_dns_rg ($afd_region)"
        fi
      fi
      # Create zone.
      if [[ "$fail" -eq 0 ]] && ! az network dns zone show $dns_sub_args -g "$afd_dns_rg" -n "$afd_domain" >/dev/null 2>&1; then
        echo "      az network dns zone create $dns_sub_args -g $afd_dns_rg -n $afd_domain"
        if ! az network dns zone create $dns_sub_args -g "$afd_dns_rg" -n "$afd_domain" >/dev/null 2>&1; then
          warn "      [!] failed to create zone — check that the parent registrar"
          warn "          permits subdomain delegation, or that the FQDN is valid."
          fail=1
        else
          echo "      [+] zone created: $afd_domain"
          ns=$(az network dns zone show $dns_sub_args -g "$afd_dns_rg" -n "$afd_domain" \
            --query "nameServers" -o tsv 2>/dev/null | tr '\t' '\n' | head -4)
          echo
          bold "  ===================================================================="
          bold "  ACTION REQUIRED: delegate $afd_domain to these Azure nameservers:"
          bold "  ===================================================================="
          printf '    %s\n' $ns
          bold "  ===================================================================="
          echo "  Paste these into your registrar's DNS panel (NS records for"
          echo "  the apex of $afd_domain). DNS propagation: 5-60 min, sometimes"
          echo "  longer for fresh domains. AFD cert validation needs the NS"
          echo "  records visible publicly before it can issue managed certs."
          echo
          warn "  AFD validation will FAIL if you apply before NS delegation"
          warn "  resolves. Verify with:  dig NS $afd_domain +short"
        fi
      fi
    fi
  fi

  # 2. Marketplace terms. Enumerate every `os:` value referenced in the
  # scenario YAML and look it up in images.tf via _dump_image_map. We
  # use the --plan form (publisher/offer/sku, no version) so we don't
  # depend on `latest` resolving — some SKUs publish multiple versions
  # but the terms are scoped to the SKU itself.
  #
  # Lookup table encoded as multi-line "<os>|<pub>|<offer>|<sku>" so
  # it works on bash 3.2 (no associative arrays).
  image_lookup=$(_dump_image_map)

  # Build dedup list of "<pub>|<offer>|<sku>|<os>" entries for every
  # os referenced in the scenario YAML. Single string, sort -u for
  # dedup, then iterate via while-read.
  scenario_oses=$(grep -oE '\bos:\s*[a-z0-9-]+' "$yaml" | awk '{print $2}' | sort -u)
  need_terms=""
  while IFS= read -r os_name; do
    [[ -z "$os_name" ]] && continue
    entry=$(echo "$image_lookup" | awk -F'|' -v o="$os_name" '$1==o{print $2"|"$3"|"$4; exit}')
    if [[ -z "$entry" ]]; then
      warn "  [!] os '$os_name' referenced in $yaml has no entry in images.tf"
      fail=1
      continue
    fi
    need_terms="$need_terms${need_terms:+$'\n'}$entry|$os_name"
  done <<<"$scenario_oses"
  need_terms=$(echo "$need_terms" | sort -u)

  while IFS='|' read -r pub offer sku label; do
    [[ -z "$pub" ]] && continue
    accepted=$(az vm image terms show --publisher "$pub" --offer "$offer" \
        --plan "$sku" --query accepted -o tsv 2>/dev/null || echo "")
    if [[ "$accepted" == "true" ]]; then
      echo "  [+] Marketplace terms accepted: $label  ($pub:$offer plan=$sku)"
    elif [[ -z "$accepted" ]]; then
      # Some SKUs (e.g. WindowsServer, Debian, Ubuntu, kali) have no
      # Marketplace terms at all — `terms show` returns nothing rather
      # than `accepted: false`. Treat as a soft note, not a failure.
      echo "  [.] Marketplace terms not required: $label  ($pub:$offer plan=$sku)"
    else
      warn "  [!] Marketplace terms NOT accepted: $label  ($pub:$offer plan=$sku)"
      warn "      run: az vm image terms accept --publisher $pub --offer $offer --plan $sku"
      warn "      OR:  ./range accept-marketplace      (accept ALL SKUs at once)"
      fail=1
    fi
  done <<<"$need_terms"

  echo
  bold "Quota + cost estimate"
  if [[ ! -f "$ENV_DIR/terraform.tfvars.json" ]]; then
    warn "  tfvars not found — run ./range gen $name first"
  else
    set +e
    python3 "$REPO/scripts/quota-cost.py" "$ENV_DIR/terraform.tfvars.json"
    rc=$?
    set -e
    case $rc in
      0) ;;                                        # quota fine
      2) warn "  Quota would be exceeded — request an increase before applying"
         fail=1 ;;
      *) warn "  quota-cost.py returned $rc; cost report incomplete" ;;
    esac
  fi

  echo
  if [[ "$fail" -eq 0 ]]; then
    bold "  All pre-flight checks passed."
  else
    warn "  Pre-flight checks raised warnings — apply may fail."
  fi
  return $fail
}

# Auto-refresh geofence CIDR data if a scenario uses
# `guacamole_allow_countries:` and any of the listed country files
# are missing. Runs scripts/refresh-geofence.sh transparently before
# generation. Operator can skip by pre-running the script themselves.
ensure_geofence_for() {
  local yaml="$1"
  # Pull the country codes out of the YAML — handles BOTH forms:
  #   guacamole_allow_countries: [SG, PH, AE]      # inline
  #   guacamole_allow_countries:                   # block
  #     - SG
  #     - PH
  # Earlier awk swept all 2-letter tokens after the key and was
  # picking up English words from prose comments (IP, OF, ON, OR);
  # the new parser only reads the value of the key itself, then
  # validates each token against an ISO 3166-1 alpha-2 allowlist
  # so a typo in the YAML can't trigger a 404 download spree.
  local codes
  codes=$(awk '
    BEGIN { mode = "" }
    # Match the key line. Capture everything after the colon.
    /^[[:space:]]*guacamole_allow_countries[[:space:]]*:/ {
      val = $0
      sub(/^[^:]*:[[:space:]]*/, "", val)   # drop "<key>:"
      sub(/[[:space:]]*#.*$/, "", val)      # drop trailing # comment
      if (val ~ /^\[.*\]/) {
        # Inline list: extract tokens between [ and ]
        gsub(/[][,]/, " ", val)
        n = split(val, parts, /[[:space:]]+/)
        for (i=1; i<=n; i++) {
          t = parts[i]
          if (t ~ /^[A-Za-z]{2}$/) print toupper(t)
        }
        mode = ""
      } else if (val == "" || val ~ /^>$/ || val ~ /^\|$/) {
        # Block-list form: codes appear on subsequent lines
        mode = "block"
      } else {
        mode = ""
      }
      next
    }
    # Inside a block list: each indented `- XX` line.
    mode == "block" && /^[[:space:]]+-[[:space:]]+[A-Za-z]{2}[[:space:]]*$/ {
      gsub(/[[:space:]]/, "", $0); sub(/^-/, "", $0)
      if ($0 ~ /^[A-Za-z]{2}$/) print toupper($0)
      next
    }
    # Block ends at the next top-level key (or EOF).
    mode == "block" && /^[A-Za-z_]+[[:space:]]*:/ { mode = "" }
  ' "$yaml" | sort -u | tr '\n' ' ')

  # ISO 3166-1 alpha-2 allowlist filter — defends against parser bugs
  # AND scenario typos. ipdeny.com 404s on anything not listed here
  # anyway; better to drop noise locally than spam HTTP errors.
  if [[ -n "$codes" ]]; then
    codes=$(printf '%s\n' $codes | grep -E \
      '^(AD|AE|AF|AG|AI|AL|AM|AO|AQ|AR|AS|AT|AU|AW|AX|AZ|BA|BB|BD|BE|BF|BG|BH|BI|BJ|BL|BM|BN|BO|BQ|BR|BS|BT|BV|BW|BY|BZ|CA|CC|CD|CF|CG|CH|CI|CK|CL|CM|CN|CO|CR|CU|CV|CW|CX|CY|CZ|DE|DJ|DK|DM|DO|DZ|EC|EE|EG|EH|ER|ES|ET|FI|FJ|FK|FM|FO|FR|GA|GB|GD|GE|GF|GG|GH|GI|GL|GM|GN|GP|GQ|GR|GS|GT|GU|GW|GY|HK|HM|HN|HR|HT|HU|ID|IE|IL|IM|IN|IO|IQ|IR|IS|IT|JE|JM|JO|JP|KE|KG|KH|KI|KM|KN|KP|KR|KW|KY|KZ|LA|LB|LC|LI|LK|LR|LS|LT|LU|LV|LY|MA|MC|MD|ME|MF|MG|MH|MK|ML|MM|MN|MO|MP|MQ|MR|MS|MT|MU|MV|MW|MX|MY|MZ|NA|NC|NE|NF|NG|NI|NL|NO|NP|NR|NU|NZ|OM|PA|PE|PF|PG|PH|PK|PL|PM|PN|PR|PS|PT|PW|PY|QA|RE|RO|RS|RU|RW|SA|SB|SC|SD|SE|SG|SH|SI|SJ|SK|SL|SM|SN|SO|SR|SS|ST|SV|SX|SY|SZ|TC|TD|TF|TG|TH|TJ|TK|TL|TM|TN|TO|TR|TT|TV|TW|TZ|UA|UG|UM|US|UY|UZ|VA|VC|VE|VG|VI|VN|VU|WF|WS|YE|YT|ZA|ZM|ZW)$' | tr '\n' ' ')
  fi
  [[ -z "$codes" ]] && return 0   # scenario doesn't use geofence

  local missing=""
  for cc in $codes; do
    [[ -f "$REPO/geofence/${cc}.txt" && -s "$REPO/geofence/${cc}.txt" ]] || missing+=" $cc"
  done
  if [[ -n "$missing" ]]; then
    bold "Geofence CIDRs missing for:$missing — fetching from ipdeny.com..."
    "$REPO/scripts/refresh-geofence.sh" $missing
  fi
}

# Force-teardown helper. Find every RG tagged Range=<name> and queue
# `az group delete --no-wait`. Use when `terraform destroy` is hung or
# state is corrupt. After this completes Azure-side, also wipe the
# local state (`rm -rf envs/azure/.terraform envs/azure/terraform.tfstate*`)
# or terraform won't realise the resources are gone.
nuke_range() {
  # Escape-hatch teardown — faster (for the operator) than `terraform
  # destroy`, which blocks ~20-60 min on AFD managed-cert revocation.
  # Three steps, ONE confirmation:
  #   1. Delete the DNS records this range created in EXTERNAL zones —
  #      AFD CNAMEs + _dnsauth validation TXTs + the Guacamole A record.
  #      Those live in enterprisesstudio.com / cyberwarrange.com, NOT in
  #      the range's tagged RGs, so `az group delete` never touches them.
  #      Left behind they're cruft, and stale _dnsauth TXTs can confuse
  #      AFD cert validation on the NEXT deploy. We read them out of
  #      terraform state (while it still exists) and `az`-delete each —
  #      they may span multiple RGs and even subscriptions, so we parse
  #      sub/rg/zone/type/name from each record's ARM id.
  #   2. `az group delete --no-wait` every RG tagged Range=<name> — async;
  #      returns immediately, Azure tears them down in the background.
  #   3. Wipe local terraform state (backed up to /tmp first).
  # Net: the command returns in well under a minute, nothing is orphaned,
  # and a fresh `./range gen + apply` won't collide — wiped state means
  # fresh random names, and the cleaned zone has no leftover records.
  command -v az >/dev/null 2>&1 || die "az CLI required for nuke"
  local range_name="${1:-}"
  [[ -n "$range_name" ]] || die "usage: ./range nuke <range_name>"

  # ---- 1. Discover RGs tagged Range=<range_name> ----
  bold "Searching for RGs tagged Range=$range_name ..."
  local rgs_list rgs dns_records dns_raw line
  local rec rtype rsub rrg rzone rname rg sub_arg confirm stamp backup
  rgs_list=$(az group list --query "[?tags.Range=='$range_name'].name" -o tsv)
  # bash 3.2: read into array via newline-split (no mapfile).
  rgs=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && rgs+=("$line")
  done <<<"$rgs_list"

  # ---- 2. Discover the range's DNS records from terraform state ----
  # The python program is fed via `python3 -` (heredoc); it invokes
  # `terraform show -json` ITSELF (cwd=$ENV_DIR) rather than us piping
  # into it, so stdin stays free for the program. Emits one
  #   <rectype>|<sub>|<rg>|<zone>|<name>
  # line per DNS record found anywhere in state (root + child modules).
  dns_records=()
  if command -v terraform >/dev/null 2>&1 && [[ -d "$ENV_DIR/.terraform" ]]; then
    dns_raw=$(TERRA_ENV_DIR="$ENV_DIR" python3 - <<'PY'
import json, os, subprocess, sys
r = subprocess.run(["terraform", "show", "-json"],
                   cwd=os.environ["TERRA_ENV_DIR"],
                   capture_output=True, text=True, check=False)
if r.returncode != 0:
    sys.exit(0)
try:
    state = json.loads(r.stdout)
except Exception:
    sys.exit(0)
DNS_TYPES = {
    "azurerm_dns_a_record":     "a",
    "azurerm_dns_cname_record": "cname",
    "azurerm_dns_txt_record":   "txt",
    "azurerm_dns_aaaa_record":  "aaaa",
}
seen = set()
def walk(node):
    if isinstance(node, dict):
        t = node.get("type")
        if t in DNS_TYPES and isinstance(node.get("values"), dict):
            v = node["values"]
            rid  = v.get("id", "") or ""
            name = v.get("name", "")
            zone = v.get("zone_name", "")
            rg   = v.get("resource_group_name", "")
            sub  = ""
            parts = rid.split("/")
            if "subscriptions" in parts:
                i = parts.index("subscriptions")
                if i + 1 < len(parts):
                    sub = parts[i + 1]
            if name and zone and rg:
                key = (DNS_TYPES[t], sub, rg, zone, name)
                if key not in seen:
                    seen.add(key)
                    print("%s|%s|%s|%s|%s" % key)
        for vv in node.values():
            walk(vv)
    elif isinstance(node, list):
        for vv in node:
            walk(vv)
walk(state)
PY
)
    while IFS= read -r line; do
      [[ -n "$line" ]] && dns_records+=("$line")
    done <<<"$dns_raw"
  else
    warn "terraform / local state not available — DNS-record cleanup will"
    warn "be SKIPPED (RGs are still nuked). Clean stale records by hand."
  fi

  # ---- Nothing to do? ----
  if [[ ${#rgs[@]} -eq 0 && ${#dns_records[@]} -eq 0 ]]; then
    warn "No RGs tagged Range=$range_name and no DNS records in state."
    warn "Nothing to nuke."
    return 0
  fi

  # ---- 3. Show the full plan + ONE confirmation ----
  echo
  if [[ ${#rgs[@]} -gt 0 ]]; then
    echo "Resource groups — async delete (az group delete --no-wait):"
    printf '  - %s\n' "${rgs[@]}"
  else
    warn "No RGs tagged Range=$range_name (already gone?)."
  fi
  echo
  if [[ ${#dns_records[@]} -gt 0 ]]; then
    echo "DNS records — deleted now (external zones; not in the tagged RGs):"
    for rec in "${dns_records[@]}"; do
      IFS='|' read -r rtype rsub rrg rzone rname <<<"$rec"
      printf '  - %-5s %s   (zone %s, rg %s)\n' "$rtype" "$rname" "$rzone" "$rrg"
    done
  fi
  echo
  warn "This ALSO wipes local terraform state ($ENV_DIR/.terraform + tfstate*)."
  warn "A backup of terraform.tfstate is saved to /tmp first."
  read -r -p "Type 'NUKE' to confirm (anything else aborts): " confirm
  [[ "$confirm" == "NUKE" ]] || die "aborted"

  # ---- 4. Delete the DNS records (synchronous; fast) ----
  if [[ ${#dns_records[@]} -gt 0 ]]; then
    bold "Deleting DNS records ..."
    for rec in "${dns_records[@]}"; do
      IFS='|' read -r rtype rsub rrg rzone rname <<<"$rec"
      sub_arg=()
      [[ -n "$rsub" ]] && sub_arg=(--subscription "$rsub")
      echo "  az network dns record-set $rtype delete -z $rzone -n $rname (rg $rrg)"
      az network dns record-set "$rtype" delete \
        "${sub_arg[@]}" -g "$rrg" -z "$rzone" -n "$rname" --yes >/dev/null 2>&1 \
        || warn "    failed: $rtype '$rname' in $rzone (zone lock, or already gone)"
    done
    echo
  fi

  # ---- 5. Queue the RG deletions (async) ----
  if [[ ${#rgs[@]} -gt 0 ]]; then
    bold "Queueing resource-group deletions (async) ..."
    for rg in "${rgs[@]}"; do
      echo "  az group delete --no-wait -n $rg"
      az group delete --no-wait --yes -n "$rg" >/dev/null 2>&1 \
        || warn "    failed to queue $rg"
    done
    echo
  fi

  # ---- 6. Wipe local terraform state (backed up to /tmp first) ----
  stamp="$(date +%Y%m%d-%H%M%S)"
  if [[ -f "$ENV_DIR/terraform.tfstate" ]]; then
    backup="/tmp/range-nuke-${range_name}-${stamp}.tfstate"
    cp "$ENV_DIR/terraform.tfstate" "$backup" 2>/dev/null \
      && bold "  terraform.tfstate backed up to $backup"
  fi
  rm -rf "$ENV_DIR/.terraform" "$ENV_DIR"/terraform.tfstate*

  echo
  bold "Nuke complete:"
  bold "  - DNS records : deleted synchronously"
  bold "  - RGs         : async deletion queued — Azure works through them"
  bold "                  in the background. Track: az group list -o table"
  bold "  - local state : wiped (backup in /tmp)"
  bold "Safe to './range gen <scenario>' + apply a new range now — fresh"
  bold "state + fresh random names, and the cleaned zone has nothing left"
  bold "to collide with while the async RG teardown finishes."
}

case "$cmd" in
  list|ls)
    bold "Available scenarios:"
    for f in "$SCENARIO_DIR"/*.yaml; do
      [[ -f "$f" ]] || continue
      name="$(basename "$f" .yaml)"
      desc="$(grep -m1 '^# Purpose:' "$f" | sed 's/^# Purpose: *//')"
      cost="$(grep -m1 '^# Cost'    "$f" | sed 's/^# Cost   *: *//')"
      printf "  %-15s  %s\n" "$name" "$desc"
      [[ -n "$cost" ]] && printf "  %-15s  cost: %s\n" "" "$cost"
    done
    if [[ -f "$ACTIVE_FILE" ]]; then
      echo
      bold "Currently active: $(cat "$ACTIVE_FILE")"
    fi
    ;;

  gen|generate)
    yaml="$(require_scenario "${1:-}")"
    shift  # consume scenario name; remaining args pass through to generator
    ensure_geofence_for "$yaml"
    # Inject --provider when the user passed --aws / --gcp on the wrapper.
    # The YAML's `provider:` field is the default; the wrapper flag wins.
    # generate.py understands `--provider aws|azure|gcp|both`.
    gen_prov=()
    [[ "$PROVIDER" != "azure" ]] && gen_prov=(--provider "$PROVIDER")
    python3 "$REPO/generator/generate.py" "$yaml" "${gen_prov[@]}" "$@"
    basename "$yaml" .yaml > "$ACTIVE_FILE"
    bold "Active scenario: $(cat "$ACTIVE_FILE") (provider: $PROVIDER)"
    ;;

  plan)
    yaml="$(require_scenario "${1:-}")"
    shift
    ensure_geofence_for "$yaml"
    gen_prov=()
    [[ "$PROVIDER" != "azure" ]] && gen_prov=(--provider "$PROVIDER")
    python3 "$REPO/generator/generate.py" "$yaml" "${gen_prov[@]}" "$@"
    basename "$yaml" .yaml > "$ACTIVE_FILE"
    # Prompt on plan so the diff matches what apply will compute.
    # Empty input is fine for plan-only — terraform sees empty brc4_*
    # vars and shows the BRC4 VM as deployable-but-unactivated.
    prompt_brc4_if_needed "$yaml"
    cd "$ENV_DIR"
    [[ -d .terraform ]] || terraform init
    terraform plan
    ;;

  apply)
    yaml="$(require_scenario "${1:-}")"
    shift
    # Detect --yes / --force in the trailing args; everything else is
    # forwarded to the generator (e.g. --domain, --students).
    force=0
    no_repair=0
    auto_bake=1       # ON by default: detect missing baked images + bootstrap
    repair_wait=600   # 10 min default wait before auto-repair
    gen_args=()
    # Flags forwarded to the post-apply repair pass (apply ends by
    # invoking `./range repair` via _post_apply_configure). Same
    # vocabulary as `./range repair` for symmetry: `--add kali` here
    # means "do terraform, then in the ansible phase run ONLY the kali
    # role". --tags and --limit work the same way.
    repair_pass_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --yes|--force)    force=1; shift ;;
        --no-repair)      no_repair=1; shift ;;
        # Skip the pre-apply baked-image detection + bootstrap. Use when
        # you know all baked images already exist (or when you want apply
        # to fail loudly on a missing baked image rather than auto-bake).
        --no-auto-bake)   auto_bake=0; shift ;;
        --repair-wait=*)  repair_wait="${1#--repair-wait=}"; shift ;;
        --add=*)          repair_pass_args+=("--add" "${1#*=}"); shift ;;
        --add)            repair_pass_args+=("--add" "$2"); shift 2 ;;
        --tags=*)         repair_pass_args+=("--tags" "${1#*=}"); shift ;;
        --tags)           repair_pass_args+=("--tags" "$2"); shift 2 ;;
        --limit=*)        repair_pass_args+=("--limit" "${1#*=}"); shift ;;
        --limit)          repair_pass_args+=("--limit" "$2"); shift 2 ;;
        # Forward --student through to the repair pass too — same
        # multi-student-shared-mode scoping as `./range repair --student`.
        --student=*)      repair_pass_args+=("--student" "${1#*=}"); shift ;;
        --student)        repair_pass_args+=("--student" "$2"); shift 2 ;;
        *)                gen_args+=("$1"); shift ;;
      esac
    done

    # Prompt for BRC4 license BEFORE generation so the generator can
    # skip BRC4 VMs entirely when the operator chose to omit the
    # license. Saves the cost of a Debian VM that would have just
    # exited cloud-init cleanly with no service running.
    # `$force` (=1 when --yes/--force passed) bypasses the prompt and
    # leaves BRC4 unconfigured — required for unattended CI/automation.
    prompt_brc4_if_needed "$yaml" "$force"

    gen_prov=()
    [[ "$PROVIDER" != "azure" ]] && gen_prov=(--provider "$PROVIDER")
    python3 "$REPO/generator/generate.py" "$yaml" "${gen_prov[@]}" "${gen_args[@]}"
    basename "$yaml" .yaml > "$ACTIVE_FILE"

    # Pre-flight is now blocking by default. If anything fails (Marketplace
    # terms, quota exceeded, az not logged in), apply prompts for an
    # explicit "yes" to override. Pass --yes / --force to bypass for
    # automation/CI.
    set +e
    preflight_checks "$yaml"
    pf_rc=$?
    set -e
    if [[ "$pf_rc" -ne 0 ]]; then
      echo
      warn "Pre-flight raised issues. Continuing risks apply failures."
      if [[ "$force" -eq 1 ]]; then
        warn "  (--yes/--force passed → overriding)"
      else
        read -r -p "Type 'yes' to apply anyway, anything else to abort: " confirm
        [[ "$confirm" == "yes" ]] || die "aborted by operator"
      fi
    fi

    # Pre-apply baked-image bootstrap. On fresh Azure accounts (or any
    # subscription where a scenario's `use_baked_*: true` flag refers to
    # a SIG image-definition with no published version yet), the main
    # terraform apply would fail at the `data.azurerm_shared_image_version`
    # lookup with "no version found". This pre-pass detects that, builds
    # the SIG infra slot if needed, and runs `./range bake <target>` for
    # each missing image so the main apply can find a published version.
    #
    # Idempotent: returns immediately if every referenced baked image
    # already has a version. Skipped entirely with --no-auto-bake.
    if [[ "$auto_bake" -eq 1 ]]; then
      _ensure_baked_images_exist "$yaml" "$force"
    else
      warn "--no-auto-bake set; skipping baked-image bootstrap. Apply will fail if any use_baked_* image has no published SIG version."
    fi

    cd "$ENV_DIR"
    [[ -d .terraform ]] || terraform init

    # Apply with auto-import retry. If apply fails with "already exists
    # - to be managed via Terraform" errors, parse the offending IDs +
    # addresses out of the log, `terraform import` each, and retry.
    #
    # Max 5 attempts (was 3). Bumped after a post-destroy reapply that
    # had to import 5 baking-related orphans serially — RG, gallery,
    # win-server-2022-ad, kali-redteam, kali-minimal — and terraform
    # only surfaces the FIRST blocking error per attempt (downstream
    # resources are skipped because their parent failed). Five attempts
    # comfortably covers the typical baking-resource chain plus any
    # one-off network orphan. At ~30-60s per attempt the worst case is
    # ~5 min of extra wall time — still bounded vs a manual re-run.
    apply_log=$(mktemp -t range-apply.XXXXXX)
    trap 'rm -f "$apply_log"' EXIT
    apply_attempt=0
    apply_rc=0
    while true; do
      apply_attempt=$((apply_attempt + 1))
      # First attempt shows the plan and prompts the operator for "yes"
      # (so they can sanity-check what's about to change). Subsequent
      # retries — which fire ONLY after auto-import resolved an
      # "already exists" error and the script is replaying the same
      # intent — use -auto-approve. Re-prompting on every retry was
      # surprising: the operator confirms once, then auto-import does
      # its housekeeping, and the SAME plan reappears for a re-confirm.
      # The desired state was already approved; the retry is mechanical.
      #
      # If the operator wants every attempt to prompt explicitly (e.g.
      # they want to abort mid-retry-chain if something looks off), they
      # can Ctrl+C between attempts — the script's `set -e` plus the
      # tee'd log preserves state for a manual re-run.
      set +e
      # First attempt: prompt for "yes" UNLESS --yes/--force was passed
      # (in which case the operator explicitly asked for non-interactive
      # mode). Retries always -auto-approve (same approved intent,
      # replaying after an auto-import).
      if [[ "$apply_attempt" -eq 1 && "$force" -ne 1 ]]; then
        terraform apply 2>&1 | tee "$apply_log"
      else
        terraform apply -auto-approve 2>&1 | tee "$apply_log"
      fi
      apply_rc=${PIPESTATUS[0]}
      set -e
      if [[ "$apply_rc" -eq 0 ]]; then
        break
      fi
      if [[ "$apply_attempt" -ge 5 ]]; then
        warn "Apply failed after $apply_attempt attempt(s); giving up."
        break
      fi
      if grep -q "already exists - to be managed via Terraform" "$apply_log"; then
        echo
        bold "Detected orphan resource(s) from a previous partial apply."
        if _auto_import_orphans "$apply_log"; then
          echo
          bold "Re-running apply (attempt $((apply_attempt + 1)) of 5, -auto-approve)..."
          continue
        fi
      fi
      # Unknown / unrecoverable error — stop retrying.
      break
    done
    rm -f "$apply_log"
    trap - EXIT

    if [[ "$apply_rc" -ne 0 ]]; then
      die "terraform apply failed (rc=$apply_rc) — fix the underlying issue and re-run."
    fi

    # ---- Auto-repair pass --------------------------------------------------
    # ALWAYS runs unless --no-repair. The wait is conditional:
    #   - If terraform actually replaced/created VMs    -> wait ~10 min for
    #     cloud-init to attempt its first run, then repair.
    #   - If terraform made zero changes (idempotent re-apply, or only
    #     drift fixes on existing resources)            -> skip the wait,
    #     run repair immediately. Existing VMs are presumed already past
    #     first-boot, so repair finds stale state right away.
    if [[ "$no_repair" -eq 1 ]]; then
      echo
      warn "--no-repair set; skipping post-apply auto-repair."
      warn "Run './range repair' manually if anything looks off."
    else
      # Parse the "Apply complete!" line for change counts. Format:
      #   Apply complete! Resources: 5 added, 2 changed, 0 destroyed.
      apply_summary=$(grep -oE 'Apply complete! Resources: [0-9]+ added, [0-9]+ changed, [0-9]+ destroyed' "$apply_log" 2>/dev/null | tail -n1 || echo "")
      added=$(echo "$apply_summary"   | grep -oE '[0-9]+ added'     | grep -oE '[0-9]+' || echo 0)
      changed=$(echo "$apply_summary" | grep -oE '[0-9]+ changed'   | grep -oE '[0-9]+' || echo 0)
      destroyed=$(echo "$apply_summary" | grep -oE '[0-9]+ destroyed' | grep -oE '[0-9]+' || echo 0)
      total_change=$(( added + changed + destroyed ))

      if [[ "$total_change" -eq 0 ]]; then
        echo
        bold "No infrastructure changes this apply — running auto-repair immediately."
      else
        echo
        bold "Apply touched $total_change resource(s) (+$added/~$changed/-$destroyed)."
        bold "Waiting ${repair_wait}s (~$((repair_wait / 60)) min) for cloud-init to attempt first run..."
        echo "  Override with --repair-wait=<seconds>, or skip entirely with --no-repair."
        sleep "$repair_wait"
        echo
        bold "Running auto-repair pass (idempotent; safe if everything is already healthy)..."
      fi
      # Post-apply configuration is owned by Ansible
      # (modules/azure/ansible/playbook.yml). The playbook is
      # idempotent and retries within each task -- no outer retry
      # loop needed. Falls back to the legacy az-run-command repair
      # pass if ansible-playbook is missing, so a fresh checkout on
      # a machine without ansible installed still gets SOMETHING.
      _post_apply_configure "${repair_pass_args[@]}"
      echo
      echo "  Run './range health' for the full per-VM summary."
    fi

    echo
    bold "Done. Cloud-init / Windows bootstrap is STILL RUNNING:"
    echo
    echo "  Wall time between 'terraform apply finished' and 'fully ready':"
    echo "    Adaptix     ~15-20 min  (Go install + git clone + go build server-ext)"
    echo "    Mythic      ~20-30 min  (docker pulls + mythic-cli build + 5 listeners)"
    echo "    Sliver       ~5-10 min  (release binary + listener creation)"
    echo "    BRC4         ~5-10 min  (blob download + license activation)"
    echo "    Win DC       ~10-15 min (AD promo + reboot + lab-users seeding)"
    echo "    Win members  ~5-10 min  (after DC) (domain join + reboot)"
    echo
    bold "What you can do RIGHT NOW (cloud-init not yet finished):"
    echo "  ./range creds                  — credentials + URLs + SSH key path"
    echo "  ./range health                 — query every VM remotely (no SSH needed)"
    echo "  ./range fix <vm-name>          — re-run cloud-init on a stuck VM"
    echo "  ./range diag                   — exact log paths per VM type"
    echo "  ./range afd-status             — AFD cert validation state"
    echo
    bold "If something STILL isn't up after the timings above:"
    echo "  1. Open Guacamole in browser, log in as 'guacadmin' / (creds output)"
    echo "  2. Click the Kali SSH connection (Kali is the only Linux that doesn't"
    echo "     need a long bootstrap — should be up in <5 min)"
    echo "  3. From Kali, SSH directly to the failing VM:"
    echo "       ssh ranger@10.X.1.5    # Adaptix"
    echo "       ssh ranger@10.X.1.7    # Mythic"
    echo "       ssh ranger@10.X.1.9    # BRC4"
    echo "       ssh ranger@10.X.1.11   # Sliver"
    echo "     Password is 'Lab!Linux1' (or from ./range creds for the SSH key)"
    echo "  4. Check: cloud-init status; sudo tail /var/log/cloud-init-output.log"
    echo
    bold "If Windows RDP shows 'Authentication failed' via Guacamole:"
    echo "  - The 'rangeadmin' local user is created by the bootstrap RunCommand."
    echo "  - Until that completes, the Guacamole RDP connection has no valid creds."
    echo "  - Check ./range diag and run the diagnostic commands listed."
    ;;

  output|outputs)
    cd "$ENV_DIR"
    bold "Public URLs:"
    terraform output guacamole_url 2>/dev/null || true
    terraform output elk_kibana_url 2>/dev/null || true
    echo
    bold "Admin credentials (sensitive — masked here):"
    echo "  guacamole admin pw: terraform output -raw guacamole_admin_password"
    echo "  per-student logins: terraform output -json student_logins"
    echo "  c2 connections:     terraform output -json adaptix_connections"
    echo "  shared infra:       terraform output -json shared_infra"
    echo "  AFD endpoint:       terraform output -json advanced_c2"
    echo
    echo "  TIP: ./range creds      — print every credential in one shot"
    echo
    bold "Summary:"
    terraform output summary 2>/dev/null || true
    ;;

  creds|credentials|secrets)
    # Single-command dump of EVERY credential terraform knows about.
    # No SSH, no piecewise `terraform output -raw ...` invocations.
    # Pretty-prints sensitive values inline; pipe to `less -R` if your
    # terminal eats the colors, or `| tee ~/range-creds.txt` to capture.
    cd "$ENV_DIR"
