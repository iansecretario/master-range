        fi
      done
      if [[ "${#gp_tag_list[@]}" -eq 0 ]]; then
        die "--c2 was empty after parsing (try: --c2 mythic,sliver)"
      fi
      # Comma-join (bash 3.2-safe).
      gp_tags=""
      for t in "${gp_tag_list[@]}"; do gp_tags="${gp_tags:+$gp_tags,}$t"; done
      bold "Generating payloads for: $gp_seen"
    fi

    exec "$0" "--$PROVIDER" repair \
      --tags "$gp_tags" \
      "${gp_forward[@]}"
    ;;

  repair)
    # Configure / repair every C2 teamserver, redirector, and Guacamole
    # via Ansible. The playbook is fully idempotent — every task is
    # "is this already in the desired state? if not, fix it." Safe to
    # re-run any time. Uses SSH to the public-IP-exposed boxes
    # (redirectors, guacamole) and ProxyJump through the redirector
    # for teamservers (which have no public IP).
    #
    # Flags:
    #   --limit PATTERN   forward `--limit PATTERN` to ansible (e.g. `adaptix`,
    #                     `redteam-lab-mythic`). Defaults to all hosts.
    #   --check           dry run (ansible --check); shows what would change.
    #   --tags T          ansible --tags passthrough.
    #   --verbose / -v    bump ansible verbosity (-vv).
    #   --legacy          use the old `az vm run-command invoke` repair pass
    #                     (kept as a fallback while we migrate).
    #   --retry N         only relevant with --legacy.
    cd "$ENV_DIR"
    ans_limit=""
    ans_student=""
    ans_extra=()
    use_legacy=0
    skip_preflight=0
    skip_ssh_heal=0
    repair_retry=3
    repair_wait_between=90
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --limit=*)   ans_limit="${1#*=}"; shift ;;
        --limit)     ans_limit="$2"; shift 2 ;;
        # --student <sid> scopes the repair to a single student's
        # machines in multi-student `shared` mode deploys. Translates to
        # an ansible `--limit '*-<sid>-*'` pattern that matches every
        # per-student VM name (e.g. lab01-kali, lab01-adaptix,
        # lab01-mythic, lab01-sliver, lab01-adaptix-redir, ...) — the
        # generator names per-student machines as `<sid>-<base>` and
        # terraform prepends `<range_name>-`, so the inventory hostname
        # is `<range_name>-<sid>-<base>`. The `*-<sid>-*` glob hits all
        # of them while leaving shared targets (dc01, srv01, ...) and
        # other students alone.
        # Mutually exclusive with --limit (the operator would otherwise
        # have to remember the wildcard form themselves).
        --student=*) ans_student="${1#*=}"; shift ;;
        --student)   ans_student="$2"; shift 2 ;;
        --check)     ans_extra+=("--check"); shift ;;
        --tags=*)    ans_extra+=("--tags" "${1#*=}"); shift ;;
        --tags)      ans_extra+=("--tags" "$2"); shift 2 ;;
        # --add is a friendlier alias for --tags. Every play in
        # playbook.yml is tagged with its role name (common, redirector,
        # guacamole, adaptix, mythic, sliver, brc4, kali, adaptix_payload,
        # mythic_payload, sliver_payload, brc4_payload), so e.g.
        # `./range repair --add kali` runs ONLY the kali play and skips
        # everything else in the playbook.
        --add=*)     ans_extra+=("--tags" "${1#*=}"); shift ;;
        --add)       ans_extra+=("--tags" "$2"); shift 2 ;;
        # Passthrough for ad-hoc Jinja vars. The value is a single
        # whitespace-separated string ("key1=val1 key2=val2"); ansible-
        # playbook parses it with shlex semantics, so quote values with
        # spaces. Useful for one-off plumbing like:
        #   ./range repair --limit guacamole \
        #     -e 'terra_guacamole_fqdn=foo.cloudapp.azure.com terra_guacamole_acme_email=you@example.com'
        --extra-vars=*) ans_extra+=("--extra-vars" "${1#*=}"); shift ;;
        --extra-vars|-e) ans_extra+=("--extra-vars" "$2"); shift 2 ;;
        --verbose|-v) ans_extra+=("-vv"); shift ;;
        --legacy)    use_legacy=1; shift ;;
        --skip-preflight) skip_preflight=1; shift ;;
        # Skip the pre-ansible SSH-key heal pass (the loop that uses
        # az vm run-command to plant the operator pubkey on every
        # Linux VM via Azure's authenticated channel — workaround for
        # the cloud-init users_groups race we keep seeing on sliver +
        # mythic). Default: on. Use --no-ssh-heal if `az` isn't
        # installed locally, or you've manually verified SSH works
        # and want to save the ~1-2 min the heal pass adds.
        --no-ssh-heal) skip_ssh_heal=1; shift ;;
        --retry=*)   repair_retry="${1#*=}"; shift ;;
        --retry)     repair_retry="$2"; shift 2 ;;
        --wait=*)    repair_wait_between="${1#*=}"; shift ;;
        --wait)      repair_wait_between="$2"; shift 2 ;;
        --once)      repair_retry=1; shift ;;
        --help|-h)
          # Quoted heredoc — disables backtick/$() expansion so the
          # `--tags kali` etc. backticked snippets in the help text
          # don't get interpreted as command substitutions.
          cat <<'USAGE'
usage: ./range repair [--limit PATTERN | --student SID] [--check] [--tags T | --add R] [-v] [--legacy]
  --limit PATTERN   restrict to a group/host (adaptix, redteam-lab-mythic, ...)
  --student SID     multi-student shared-mode only: scope to ONE student's
                    machines. Expands to --limit '*-<SID>-*'. Mutually
                    exclusive with --limit. Example:
                      ./range repair --student lab01
                    converges only lab01's kali / adaptix / mythic /
                    sliver / redirectors, leaving shared targets and
                    every other student untouched.
  --check           dry-run (ansible --check); no changes applied
  --tags T          ansible tag filter — every play is tagged with its
                    role name (kali, mythic, adaptix, ...), so
                    `--tags kali` runs only the kali role.
  --add R           friendlier alias for --tags (--add kali == --tags kali)
  -v, --verbose     ansible -vv
  --legacy          fall back to the old az-run-command repair pass
                    (use --retry N --wait S to control its retry loop)
  --no-ssh-heal     skip the pre-ansible SSH-key heal pass. Default:
                    ON. The heal pass uses `az vm run-command invoke`
                    to plant the operator pubkey on every Linux VM via
                    Azure's authenticated channel — fixes the
                    cloud-init users_groups race we keep seeing on
                    sliver/mythic that leaves ranger's authorized_keys
                    empty on fresh deploys. ~5-10 sec per VM,
                    ~1-2 min total for a typical range. Skip if `az`
                    isn't installed locally, or you've manually
                    verified SSH works.
USAGE
          exit 0 ;;
        *) warn "unknown repair flag: $1"; shift ;;
      esac
    done

    # Resolve --student into --limit. Mutually exclusive — if the
    # operator passed both, error out so we don't silently drop one.
    if [[ -n "$ans_student" ]]; then
      if [[ -n "$ans_limit" ]]; then
        die "--student and --limit are mutually exclusive (--student expands to a --limit pattern internally; pick one)."
      fi
      # Match every machine name containing -<sid>- as a hyphen-bounded
      # token. inventory hostnames are `<range_name>-<sid>-<base>` (e.g.
      # student-redteam-lab-lab01-kali / -adaptix / -mythic-redir / ...),
      # so the pattern `*-<sid>-*` hits all of student <sid>'s machines
      # AND nothing else (it won't accidentally match `dc01` because
      # there's no `-<sid>-` substring there).
      ans_limit="*-${ans_student}-*"
      echo "  [--student] scoping repair to '${ans_student}' via ansible --limit '${ans_limit}'"
    fi

    if [[ "$use_legacy" -eq 1 ]]; then
      # Old code path — kept for parity while we shake out the ansible
      # implementation. Sets REPAIR_LOG_PATH and REPAIR_FINAL_STATUS.
      _do_repair_with_retry "$repair_retry" "$repair_wait_between"
      exit 0
    fi

    # Default path: Ansible.
    # Use the pre-computed $REPO absolute path (set at top of script,
    # BEFORE any subcommand cds away). Recomputing here with
    # `$(cd "$(dirname "$0")" ...)` would resolve relative to the
    # current cwd if $0 was a relative path like ./range — which is
    # almost always the case — and after `cd "$ENV_DIR"` that gives
    # the wrong directory ($ENV_DIR/modules/azure/ansible).
    ansible_dir="$REPO/modules/azure/ansible"
    if [[ ! -d "$ansible_dir" ]]; then
      die "ansible dir not found: $ansible_dir"
    fi
    if ! command -v ansible-playbook >/dev/null 2>&1; then
      die "ansible-playbook not on PATH. Install with: brew install ansible  (or pipx install ansible-core)"
    fi

    # ---- Connectivity preflight: can the operator reach guacamole? ----
    # Guac is the ansible controller. If the operator can't SSH to it,
    # nothing else matters. Fast nc probe (5s) instead of waiting for
    # ansible's 180s wait_for_connection per host.
    _repair_preflight() {
      local probe_target
      probe_target=$(TERRA_ENV="$ENV_DIR" "$ansible_dir/inventory.py" --list 2>/dev/null \
                  | python3 -c "
import json, sys
d = json.load(sys.stdin)
for h in d.get('guacamole', {}).get('hosts', []):
    pub = d['_meta']['hostvars'][h].get('terra_public_ip')
    if pub:
        print(pub); break
" 2>/dev/null)
      if [[ -z "$probe_target" ]]; then
        warn "preflight: no guacamole VM found in inventory"
        return 0
      fi
      if ! nc -z -w 5 "$probe_target" 22 >/dev/null 2>&1; then
        echo
        warn "Pre-flight: cannot reach guacamole at $probe_target:22"
        warn ""
        warn "Likely causes:"
        warn "  - your operator IP isn't in var.guacamole_ingress_cidrs"
        warn "    (same allow-list that gates Guacamole web access)"
        warn "  - the guacamole VM is stopped/deallocated"
        warn "  - your machine is on a new network (VPN/coffee shop) since"
        warn "    last running terraform apply"
        warn ""
        warn "Bypass with: ./range repair --skip-preflight"
        exit 1
      fi
      echo "  [preflight] guacamole $probe_target:22 reachable ✓"
    }
    [[ "${skip_preflight:-0}" -eq 1 ]] || _repair_preflight

    # ---- Kali auto-heal: reboot if SSH is wedged ----
    # Kali's first-boot cloud-init runs `apt install kali-linux-default`
    # (~2.5 GB). During the long compile/install windows we've seen the
    # VM go fully unresponsive — TCP :22 accepts but the SSH banner
    # exchange times out, AND `az vm run-command` (which uses waagent
    # over a separate channel) also hangs. Symptom in ansible:
    #   "Connection timed out during banner exchange"
    #   logged identically for every kali task → operator C-c's after
    #   20+ minutes of no progress.
    #
    # Auto-heal: probe TCP :22 from the guac controller 3× with a
    # 10s timeout. If all three fail, `az vm restart` the kali VM
    # (operator's local CLI session has Owner on the student subscription;
    # guacamole's MSI does NOT). Then wait up to 5 min for SSH to come
    # back before proceeding to ansible.
    #
    # Non-fatal: if the reboot fails or kali stays down, log a warning
    # and continue. Ansible's `ignore_unreachable: true` on the kali
    # play means the rest of the deploy still completes.
    _kali_autoheal() {
      local kali_ip kali_name range_name kali_rg
      # Discover kali's private IP + full VM name from the inventory.
      # `redteam-lab-kali` → range_name = `redteam-lab`, RG = `<range>-single-rg`.
      kali_name=$(TERRA_ENV="$ENV_DIR" "$ansible_dir/inventory.py" --list 2>/dev/null \
                  | python3 -c "
import json, sys
d = json.load(sys.stdin)
for h in d.get('kali', {}).get('hosts', []):
    print(h); break
" 2>/dev/null)
      kali_ip=$(TERRA_ENV="$ENV_DIR" "$ansible_dir/inventory.py" --list 2>/dev/null \
                | python3 -c "
import json, sys
d = json.load(sys.stdin)
for h in d.get('kali', {}).get('hosts', []):
    print(d['_meta']['hostvars'][h].get('ansible_host', '')); break
" 2>/dev/null)
      if [[ -z "$kali_ip" || -z "$kali_name" ]]; then
        echo "  [preflight] no kali host in inventory — skipping auto-heal"
        return 0
      fi
      range_name="${kali_name%-kali}"
      kali_rg="${range_name}-single-rg"

      # Probe via guac (kali has no public IP and no redirector).
      local attempt rc=1
      for attempt in 1 2 3; do
        if ssh -i "$ssh_key" -o BatchMode=yes -o StrictHostKeyChecking=no \
               -o UserKnownHostsFile=/dev/null -o ConnectTimeout=8 \
               "guacadmin@${guac_pub}" \
               "timeout 8 bash -c 'exec 3<>/dev/tcp/${kali_ip}/22 && \
                                  read -t 5 -u 3 banner && [[ \$banner == SSH-* ]]'" \
               >/dev/null 2>&1; then
          rc=0; break
        fi
        echo "  [preflight] kali ${kali_ip}:22 banner probe attempt ${attempt}/3 failed"
        sleep 4
      done
      if [[ $rc -eq 0 ]]; then
        echo "  [preflight] kali ${kali_ip}:22 reachable ✓"
        return 0
      fi

      warn "kali (${kali_name}, ${kali_ip}) is wedged — rebooting via Azure..."
      if ! az vm restart --resource-group "$kali_rg" --name "$kali_name" \
                         --no-wait 2>&1 | tail -3; then
        warn "az vm restart failed for $kali_name in $kali_rg; ansible will skip kali"
        return 0
      fi
      echo "  [preflight] reboot dispatched; waiting up to 5 min for kali SSH..."

      # Wait loop — up to 30 × 10s = 5 min.
      local i
      for i in $(seq 1 30); do
        sleep 10
        if ssh -i "$ssh_key" -o BatchMode=yes -o StrictHostKeyChecking=no \
               -o UserKnownHostsFile=/dev/null -o ConnectTimeout=8 \
               "guacadmin@${guac_pub}" \
               "timeout 8 bash -c 'exec 3<>/dev/tcp/${kali_ip}/22 && \
                                  read -t 5 -u 3 banner && [[ \$banner == SSH-* ]]'" \
               >/dev/null 2>&1; then
          echo "  [preflight] kali back up after $((i*10))s ✓"
          return 0
        fi
      done
      warn "kali still unreachable after 5 min — ansible will run with ignore_unreachable"
    }
    # The kali probe needs $ssh_key + $guac_pub set, which happens
    # below. We re-arrange the order so they're defined first.

    # ---- Resolve guacamole's public IP to use as the controller ----
    # Ansible runs ON GUACAMOLE, not on the operator's laptop. From
    # guacamole's vantage point it's inside the hub VNet (peered with
    # every student attacker subnet), so it can reach teamservers via
    # their PRIVATE IPs directly — no ProxyJump, no NSG holes on the
    # operator side. The operator just SSHes to guac and waits.
    guac_pub=$(TERRA_ENV="$ENV_DIR" "$ansible_dir/inventory.py" --list 2>/dev/null \
               | python3 -c "
import json, sys
d = json.load(sys.stdin)
for h in d.get('guacamole', {}).get('hosts', []):
    pub = d['_meta']['hostvars'][h].get('terra_public_ip')
    if pub:
        print(pub); break
" 2>/dev/null)
    [[ -n "$guac_pub" ]] || die "could not resolve guacamole's public IP from inventory"
    bold "Controller: guacadmin@${guac_pub}"

    # ---- Persistent transcript ----
    stamp="$(date +%Y%m%d-%H%M%S)"
    repair_log="/tmp/range-repair-${stamp}.log"
    bold "Configuring via Ansible (executor=guacamole). Transcript: $repair_log"

    # ---- Render inventory locally + push everything to guac ----
    # terraform state lives on the operator's laptop -- guac doesn't
    # have it. Run inventory.py's --emit-data here (it walks state
    # locally and falls back gracefully when ansible_inventory output
    # isn't computed yet). Push the resulting JSON to guac alongside
    # the playbook; guac's inventory.py reads it via $TERRA_INVENTORY_FILE.
    inv_tmp=$(mktemp -t terra-inv.XXXXXX.json)
    trap 'rm -f "$inv_tmp"' EXIT
    TERRA_ENV="$ENV_DIR" "$ansible_dir/inventory.py" --emit-data > "$inv_tmp"

    # SSH key location. Pulled from the rendered inventory data so we
    # don't have to know whether this deploy uses the new
    # labs/<range_name>/operator-id_ed25519 layout or the legacy
    # envs/azure/operator-id_ed25519 path.
    ssh_key=$(python3 -c "import json; print(json.load(open('$inv_tmp'))['ssh_private_key_path'])")
    if [[ ! -f "$ssh_key" ]]; then
      die "operator SSH private key not found at: $ssh_key  (terraform apply first?)"
    fi

    guac_ssh=(ssh -i "$ssh_key"
              -o BatchMode=yes
              -o StrictHostKeyChecking=no
              -o UserKnownHostsFile=/dev/null
              "guacadmin@${guac_pub}")

    # Kali auto-heal — runs AFTER $ssh_key and $guac_pub are resolved
    # (the function definition lives up near _repair_preflight, but it
    # needs both vars to probe kali via guac). Honor --skip-preflight.
    [[ "${skip_preflight:-0}" -eq 1 ]] || _kali_autoheal

    # Ensure the remote staging dir exists and is owned by guacadmin
    # before rsync. /opt is root-owned on a stock Ubuntu image, so the
    # very first repair would otherwise fail with mkdir EACCES. We can't
    # bake this in userdata cleanly because the dir is part of the
    # repair-time contract (not the VM image), and rsync itself can't
    # do a sudo-prefixed mkdir. Cheapest fix: one-shot the dir via ssh
    # with NOPASSWD sudo (guacadmin has it from cloud-init).
    "${guac_ssh[@]}" "sudo mkdir -p /opt/terra-range-ansible && sudo chown guacadmin:guacadmin /opt/terra-range-ansible" >/dev/null

    echo "  [sync] pushing playbook + inventory to guac:/opt/terra-range-ansible/ ..."
    rsync -az --delete \
        -e "ssh -i $ssh_key -o BatchMode=yes -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null" \
        "$ansible_dir/" "guacadmin@${guac_pub}:/opt/terra-range-ansible/" 2>&1 | tail -3
    scp -i "$ssh_key" \
        -o BatchMode=yes -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
        "$inv_tmp" "guacadmin@${guac_pub}:/opt/terra-range-ansible/inventory.json" >/dev/null

    # Deploy the operator's private key onto guac so ansible (running with
    # ANSIBLE_FROM_GUAC=1) can SSH from guac → teamserver private IPs
    # using key auth. inventory.py hardcodes
    # /home/guacadmin/.ssh/operator-id_ed25519 for the from-guac path
    # because terraform state lives on the operator's machine, not here.
    # Without this, every ansible SSH falls through to "no key" — which
    # presents as a 30s ConnectTimeout rather than a clean auth failure,
    # so the symptom is mysterious "Operation timed out" on the
    # `common : Wait for VM to be SSH-reachable` task.
    # Mode 600; guac is already a privileged admin host (operators with
    # root here can hop to all teamservers regardless).
    # HARDENED: a freshly-recreated guac VM (e.g. after a terraform
    # apply that replaced it — new public IP and all) can still be
    # finishing cloud-init when this fires. The rsync above can succeed
    # while ~/.ssh isn't settled or sshd briefly flaps, so a blind
    # `scp ... >/dev/null` here can fail SILENTLY — and without this key
    # EVERY ansible-from-guac SSH fails UNREACHABLE, breaking the whole
    # repair with mysterious 30s timeouts on every host. So: ensure
    # ~/.ssh exists, retry the push, VERIFY it actually landed, and
    # hard-fail loudly if it didn't (a clean abort beats a doomed run).
    "${guac_ssh[@]}" "mkdir -p ~/.ssh && chmod 700 ~/.ssh" >/dev/null 2>&1 || true
    key_pushed=0
    for attempt in 1 2 3 4 5; do
        if scp -i "$ssh_key" \
                -o BatchMode=yes -o StrictHostKeyChecking=no \
                -o UserKnownHostsFile=/dev/null -o ConnectTimeout=15 \
                "$ssh_key" \
                "guacadmin@${guac_pub}:/home/guacadmin/.ssh/operator-id_ed25519" \
                >/dev/null 2>&1 \
           && "${guac_ssh[@]}" "test -s /home/guacadmin/.ssh/operator-id_ed25519" \
                >/dev/null 2>&1; then
            key_pushed=1
            break
        fi
        echo "  [sync] operator-key push attempt ${attempt}/5 failed" \
             "(guac may still be booting) — retrying in 10s ..."
        sleep 10
    done
    if [[ "$key_pushed" -ne 1 ]]; then
        die "Failed to deploy the operator key to" \
            "guac:/home/guacadmin/.ssh/operator-id_ed25519 after 5 attempts." \
            "ansible-from-guac cannot auth to ANY host without it — the" \
            "repair would fail UNREACHABLE everywhere. Confirm guac" \
            "(${guac_pub}) is up and cloud-init has finished, then re-run."
    fi
    "${guac_ssh[@]}" "chmod 600 /home/guacadmin/.ssh/operator-id_ed25519" >/dev/null

    # Purge stale ansible SSH ControlMaster sockets on the controller.
    # ansible.cfg sets ControlPersist=60s, so a previous run can leave
    # sockets that survive the conntrack-kill window on Azure's SLB
    # (~4 min for established TCP, ~30s for half-open). The next run
    # reuses the dead socket and sshd on the target logs
    #   "banner exchange: ... invalid format"
    # then the ssh client hangs the full 30s ConnectTimeout — surfacing
    # as a mystery "Operation timed out" on whichever host happened to
    # draw the dead socket. Clearing the dir on every repair start
    # forces a fresh handshake per host; we lose ~100ms of ControlMaster
    # warm-up time, pay for it in reliability.
    "${guac_ssh[@]}" "rm -f /home/guacadmin/.ansible/cp/* 2>/dev/null; mkdir -p /home/guacadmin/.ansible/cp" >/dev/null || true

    # ---- Ensure ansible collections + pywinrm on guac (idempotent) ---------
    # The playbook's Windows play (windows-base role) uses ansible.windows
    # modules, which require THREE things present on the from-guac
    # controller:
    #   1. resolvelib PINNED at 0.5.4 (user-site, installed via pip).
    #      Ubuntu 22.04 jammy (what guac runs on) ships ansible-core 2.12
    #      + python3-resolvelib 0.8.1 from apt. Those two are MUTUALLY
    #      INCOMPATIBLE: 0.8.1 added an `identifier` kwarg to
    #      `find_matches()` that ansible-galaxy 2.12 doesn't pass, so
    #      `ansible-galaxy collection install ...` fails with:
    #        ERROR! Unexpected Exception, this is probably a bug:
    #        CollectionDependencyProvider.find_matches() got an
    #        unexpected keyword argument 'identifier'
    #      against ANY collection. resolvelib 0.5.4 (the version 2.12
    #      was developed against) has the pre-`identifier` signature
    #      and resolves cleanly. pip3 install --user puts it under
    #      ~/.local/lib/python3.10/site-packages, which Python's import
    #      order picks ahead of /usr/lib/python3/dist-packages, so we
    #      get the pinned version WITHOUT touching the system package
    #      (other apt packages depending on resolvelib are unaffected).
    #   2. ansible.windows + community.windows collections — installed
    #      via ansible-galaxy from requirements.yml (synced above).
    #      Galaxy picks the latest version compatible with ansible-core
    #      2.12 (currently ansible.windows 3.5 / community.windows 3.1);
    #      both still ship win_file, win_copy, win_regedit, win_shell
    #      with the same task surface windows-base uses.
    #   3. pywinrm — the Python WinRM client that ansible's winrm
    #      connection plugin depends on. We use the Debian package
    #      python3-winrm rather than pip to avoid any PEP 668
    #      "externally-managed-environment" friction (jammy doesn't
    #      enforce that yet, but the apt path is also idempotent and
    #      survives a future upgrade to noble/bookworm where it would).
    # All three are idempotent: pip skips already-installed versions
    # (returns "Requirement already satisfied"), ansible-galaxy skips
    # already-installed collection versions, apt-get install is a no-op
    # when the package is present.
    # Non-fatal on errors: if a dep install fails the playbook's Windows
    # play will fail loudly with a clearer message ("couldn't resolve
    # module/action 'ansible.windows.win_file'") and the operator can
    # debug from the per-step output below.
    echo "  [deps] ensuring resolvelib pin + ansible.windows collection + pywinrm on guac ..."
    "${guac_ssh[@]}" "
        pip3 install --user --quiet resolvelib==0.5.4 2>&1 | tail -3 ;
        cd /opt/terra-range-ansible &&
        ansible-galaxy collection install -r requirements.yml 2>&1 | tail -3 ;
        sudo apt-get install -y -q python3-winrm 2>&1 | tail -3
    " 2>&1 | tail -10 || warn "  [deps] non-fatal: resolvelib / collection / python3-winrm install reported errors — check guac"

    # ---- Pre-ansible SSH-key heal (auto-fix the cloud-init users_groups race)
    # ----------------------------------------------------------------------
    # Background: cloud-init's `users:` module on this Debian/cloud-init
    # combo non-deterministically fails to plant ssh_authorized_keys
    # (sliver + mythic have repeatedly come up with empty authorized_keys
    # despite the userdata's `users:` block AND a defensive runcmd "Step 0").
