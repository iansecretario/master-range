    # Block here until any managed RunCommand on this VM finishes,
    # so we don't immediately bounce off Azure's Conflict error.
    # max_wait_s is reduced to 180s -- per-VM, in parallel, so this
    # is bounded total wait, not added to other VMs' waits.
    wait_for_idle_runcommand(v['rg'], v['name'], max_wait_s=180)
