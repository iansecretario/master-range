#!/usr/bin/env bash
# range — one-command driver for cyber-range scenarios.
#
# Cloud provider selection (any subcommand):
#   --provider azure|aws|gcp       long form, value as next token
#   --provider=azure|aws|gcp       long form, value glued with =
#   --azure | --aws | --gcp        short form (equivalent)
#   TERRA_PROVIDER=gcp ./range ... env var (persistent across commands)
#   default = azure
#
# Provider flag can appear before OR after the subcommand:
#   ./range --provider gcp apply redteam-lab
#   ./range apply --provider gcp redteam-lab
#   ./range --gcp apply redteam-lab          # short form
#
# Per-provider tfvars live under envs/{azure,aws,gcp}/terraform.tfvars.json
# and per-provider terraform modules live under modules/{azure,aws,gcp}/.
# See README.md and docs/QUICKSTART_GCP.md for provider-specific setup.
#
# Usage:
#   ./range list                   show available scenarios
#   ./range gen <scenario>         generate tfvars from a scenario YAML
#   ./range plan <scenario>        gen + terraform plan
#   ./range apply <scenario>       gen + terraform apply
#   ./range output                 print terraform outputs (creds, URLs)
#   ./range creds                  dump EVERY credential terraform knows
#                                  about in one shot (no SSH, no piecewise
#                                  `terraform output -raw ...` calls)
#   ./range destroy                tear down whatever is currently deployed.
#                                  Default PRESERVES baked images (gallery
#                                  + image versions stay alive in Azure
#                                  so the next deploy doesn't trigger a
#                                  30-45 min rebake). Pass --purge-images
#                                  to nuke the gallery too.
#   ./range pause                  deallocate every VM (no compute charges
#                                  while paused, OS disks preserved). Use
#                                  for non-24/7 cohorts — drops cost by
#                                  ~80% if you pause overnight + weekends.
#   ./range resume                 start every paused VM. Mirror of pause.
#                                  VMs reach `running` in ~1-2 min;
#                                  services (guacamole, etc.) need ~3-4
#                                  min more before reachable. Re-run
#                                  ./range creds for a fresh magic link
#                                  after resume.
#   ./range nuke <range_name>      force-delete every RG tagged Range=<n>
#                                  (escape hatch when terraform destroy hangs)
#   ./range bake [server-2022|all] one-time-per-quarter Packer build of a
#                                  pre-baked Windows image. Cuts deploy
#                                  time from ~45 min to ~10 min after the
#                                  first bake. Requires packer + az CLI.
#   ./range health                 remote health check across EVERY VM.
#                                  Uses `az vm run-command invoke` to ask
#                                  each box for cloud-init status, service
#                                  state, errors. No SSH needed. ~30-60s.
#   ./range diag                   DEEP diagnostic: pulls build/install
#                                  logs + binary/plugin inventories +
#                                  service status from every C2,
#                                  redirector, and Guacamole VM. Use
#                                  this when health flagged a failure
#                                  and you need to see the actual error.
#   ./range fix <vm-name>          re-run cloud-init / bootstrap on a
#                                  single VM in place (for when the
#                                  initial run died partway).
#   ./range repair [flags]         manual run of the auto-repair pass.
#                                  Default uses the Ansible playbook in
#                                  modules/azure/ansible/ (idempotent).
#                                  Same logic `./range apply` runs after
#                                  terraform succeeds.
#                                    --limit P   restrict to group/host
#                                                (adaptix, mythic, ...)
#                                    --check     dry-run (no changes)
#                                    --tags T    ansible tag filter
#                                    -v          ansible -vv
#                                    --legacy    fall back to the older
#                                                az-run-command pass
#                                                (--retry N --wait S).
#                                  Transcript teed to
#                                  /tmp/range-repair-<stamp>.log.
#   ./range generate-payloads      run ONLY the payload-build plays
#                                  (adaptix / mythic / sliver / brc4)
#                                  against the Kali host. Drops binaries
#                                  into ~/Desktop/payloads/<framework>/
#                                  <YYYYMMDDTHHMMSSZ>/ with a `latest`
#                                  symlink at each framework's base dir.
#                                    --c2 LIST   comma-separated subset of
#                                                {adaptix,mythic,sliver,brc4}.
#                                                Default: all four.
#                                                Examples:
#                                                  --c2 mythic
#                                                  --c2 mythic,sliver
#                                                  --c2 adaptix,sliver
#                                  Forwards every other flag to the repair
#                                  subcommand (--limit, --check, -v,
#                                  --skip-preflight, etc.). Aliases:
#                                  `gen-payloads` / `payloads`.
#   ./range ansible <args...>      passthrough to ad-hoc `ansible` against
#                                  the live inventory. Examples:
#                                    ./range ansible all -m ping
#                                    ./range ansible adaptix -m shell \
#                                       -a 'journalctl -u adaptix -n 50'
#   ./range ansible-playbook ...   passthrough to `ansible-playbook`.
#   ./range lock                   re-apply with lockdown=true (seal NAT)
#   ./range unlock                 re-apply with lockdown=false (open NAT)
#   ./range afd-status             show AFD custom-domain validation state
#   ./range workspaces-reconcile   UPSERT the kali-2 ephemeral workspace
#                                  pool slots into the live Guacamole DB.
#                                  Use after enabling services.workspaces
#                                  on an already-deployed range — the
#                                  Guac VM has ignore_changes on
#                                  custom_data so a terraform apply alone
#                                  doesn't propagate new connections.
#   ./range preflight <scenario>   check az login + Marketplace terms +
#                                  quota + cost estimate before apply
#   ./range cost <scenario>        cost estimate only (no Azure calls)
#   ./range accept-marketplace [region] [--update-images]
#                                  bulk-accept Marketplace terms for every
#                                  published SKU under every (publisher,
#                                  offer) pair in modules/azure/images.tf.
#                                  Run this once per subscription.
#                                  --update-images also rewrites images.tf
#                                  to pin each entry to the freshest SKU
#                                  currently in Marketplace.
#
# All scenarios live in scenarios/*.yaml. Add a new file there and it
# shows up in `./range list` automatically.
#
# Generator overrides (any subcommand that runs the generator —
# gen/plan/apply/preflight/cost/diff — accepts these after the scenario):
#   --domain <fqdn>       override the AD domain (e.g. ian.local).
#                         NetBIOS auto-derived from first label.
#   --students N          override students.count
#   --admin-user <name>   override domain admin username
#   --spot                run every VM as Spot (~80% off PAYG; Azure can
#                         evict at any time). Default: Regular.
#   --fast-windows        speed knob: disable Windows Update on DC first
#                         boot + bump DC SKU to D8s_v5. Saves 10-20 min
#                         per deploy. Lab-only, not for production.
#   --no-afd-wait         skip the 20-min AFD managed-cert validation
#                         block during apply. AFD still validates async;
#                         poll via `./range afd-status`. Saves 20-30 min.
#
# Apply-only flags:
#   --yes / --force       bypass the pre-flight confirmation prompt
#   --no-repair           skip the auto-repair pass that runs after
#                         terraform apply. By default apply waits ~10 min
#                         for cloud-init to settle, then runs the same
#                         logic as `./range repair` (idempotent).
#   --repair-wait=<sec>   override the post-apply wait (default 600s).
#                         Use 0 to repair immediately (NOT recommended;
#                         cloud-init may not have finished yet).
#
# Examples:
#   ./range apply redteam-lab --domain ian.local
#   ./range apply redteam-lab --spot           # cheap-and-cheerful, evictable
#   ./range apply redteam-lab --fast-windows --no-afd-wait  # ~25 min spinup
#   ./range cost   redteam-lab --spot          # see what Spot would cost
#   ./range apply class --students 5 --admin-user darthadmin
#   ./range apply redteam-lab --spot --yes     # CI / unattended

set -euo pipefail

# This script runs on stock macOS /bin/bash 3.2 — no bash 4 features
# (associative arrays, mapfile). Lookup tables are encoded as
# pipe-delimited multi-line strings and queried with awk. See
# _kv_lookup() below for the helper.

REPO="$(cd "$(dirname "$0")" && pwd)"
SCENARIO_DIR="$REPO/scenarios"
ACTIVE_FILE="$REPO/.active-scenario"

# Provider selection. Azure is the default and most mature path; AWS is a
# parallel implementation under modules/aws/ (covers VPC + EC2 + Guacamole
# + ELK + CloudFront in place of Front Door). GCP is a smaller scaffold —
# see modules/gcp/README.md for current status. The flag is consumed
# BEFORE we shift the subcommand off so the rest of the dispatcher only
# sees its own args.
#
# Selection is sticky for the current invocation only; we do NOT write a
# .active-provider file because most operators stay on one cloud and the
# rare cross-cloud user can pass --aws / --gcp on every call. If you want
# stickiness, `export TERRA_PROVIDER=aws` once in your shell rc — that
# overrides the default below.
PROVIDER="${TERRA_PROVIDER:-azure}"
# Filter the provider flag out of the arg list so subcommands don't see
# it. Supports three forms (pick whichever reads best):
#   --aws | --azure | --gcp                  short form, single token
#   --provider gcp                           long form, value as next token
#   --provider=gcp                           long form, value glued with =
# Index-based loop (vs `for _arg in "$@"`) so we can consume two tokens
# when --provider is space-separated. Order is free-form: `./range
# --provider gcp apply foo` and `./range apply --provider gcp foo` both
# work — the flag is filtered out wherever it lands.
_filtered_args=()
_argv=("$@")
_i=0
while [[ $_i -lt ${#_argv[@]} ]]; do
  _arg="${_argv[$_i]}"
  case "$_arg" in
    --aws)   PROVIDER=aws   ;;
    --azure) PROVIDER=azure ;;
    --gcp)   PROVIDER=gcp   ;;
    --provider)
      _i=$((_i + 1))
      PROVIDER="${_argv[$_i]:-}"
      ;;
    --provider=*)
      PROVIDER="${_arg#*=}"
      ;;
    *)
      _filtered_args+=("$_arg")
      ;;
  esac
  _i=$((_i + 1))
done
set -- "${_filtered_args[@]}"

case "$PROVIDER" in
  azure|aws|gcp) ;;
  *) printf "\033[31mERROR:\033[0m unknown --provider value: %s (try azure | aws | gcp)\n" "$PROVIDER" >&2; exit 1 ;;
esac

ENV_DIR="$REPO/envs/$PROVIDER"
MODULE_DIR="$REPO/modules/$PROVIDER"

cmd="${1:-help}"
shift || true

bold() { printf "\033[1m%s\033[0m\n" "$*"; }
warn() { printf "\033[33m%s\033[0m\n" "$*" >&2; }
die()  { printf "\033[31mERROR:\033[0m %s\n" "$*" >&2; exit 1; }

# Parse modules/azure/images.tf and emit one line per OS entry as
# "<os>|<publisher>|<offer>|<sku>". Used by accept-marketplace and
# preflight so they're always in sync with what terraform actually
# deploys — no duplicate hardcoded SKU lists.
_dump_image_map() {
  python3 - "$REPO/modules/azure/images.tf" <<'PY'
import re, sys
src = open(sys.argv[1]).read()
# Strip `#` line-comments FIRST — the block regex below captures with
# [^}]+, so a stray { or } anywhere in a comment (e.g. a comment that
# mentions the marketplace `plan {}` block) would truncate the block
# and silently drop that os entry. image_map string values never
# contain `#`, so this is safe.
src = re.sub(r'#[^\n]*', '', src)
# Find each "<os>" = { ... } block in image_map.
for m in re.finditer(r'"([a-z0-9_-]+)"\s*=\s*\{([^}]+)\}', src):
    os_name, block = m.group(1), m.group(2)
    pub = re.search(r'publisher\s*=\s*"([^"]+)"', block)
    off = re.search(r'offer\s*=\s*"([^"]+)"', block)
    sku = re.search(r'sku\s*=\s*"([^"]+)"', block)
    if pub and off and sku:
        print(f"{os_name}|{pub.group(1)}|{off.group(1)}|{sku.group(1)}")
PY
}

# Detect if a scenario YAML or its generated tfvars references c2-brc4.
# If so, prompt the operator for license credentials and export as
# TF_VAR_*. Empty input = skip (license vars stay empty, BRC4 bootstrap
# detects empty creds and aborts that one VM cleanly).
prompt_brc4_if_needed() {
  local yaml_or_tfvars="$1"
  local non_interactive="${2:-0}"
  if ! grep -q 'c2-brc4' "$yaml_or_tfvars" 2>/dev/null; then
    return 0
  fi

  # Non-interactive mode (--yes/--force on apply OR TERRARANGE_NONINTERACTIVE=1
  # in the environment): skip the interactive credential prompt and leave
  # TF_VAR_brc4_* unset. The c2-brc4 VM is still provisioned by terraform
  # but its userdata sees empty license vars and exits cleanly — operator
  # can fix up later via `./range repair --tags brc4` after exporting the
  # creds manually, or by re-running `./range apply` interactively.
  if [[ "$non_interactive" -eq 1 || "${TERRARANGE_NONINTERACTIVE:-0}" -eq 1 ]]; then
    bold ""
    bold "  [BRC4] non-interactive mode (--yes/--force) → skipping BRC4 license prompt"
    bold "  [BRC4] BRC4 VM will deploy without credentials. Re-run interactively or"
    bold "  [BRC4] export TF_VAR_brc4_{license_id,activation_key,email} before applying."
    echo
    return 0
  fi

  bold ""
  bold "================================================================"
  bold "  Brute Ratel C4 detected in this scenario"
  bold "================================================================"
  echo "  The c2-brc4 role is license-gated. Provide your BRC4"
  echo "  credentials below, or press Enter to skip BRC4 install"
  echo "  (the rest of the range will deploy as normal)."
  echo
  echo "  Get credentials from your bruteratel.com license email."
  echo
  read -r -p "  License ID:           " brc4_lic_id
  read -r -p "  Activation Key:       " brc4_act_key
  read -r -p "  License Email:        " brc4_email
  read -r -p "  Blob fallback URL [optional, press Enter to skip]: " brc4_blob

  export TF_VAR_brc4_license_id="$brc4_lic_id"
  export TF_VAR_brc4_activation_key="$brc4_act_key"
  export TF_VAR_brc4_email="$brc4_email"
  export TF_VAR_brc4_blob_url="$brc4_blob"

  if [[ -z "$brc4_lic_id" ]]; then
    warn "  No license entered — BRC4 install will skip on this apply"
  else
    bold "  Credentials staged as TF_VAR_brc4_* (sensitive)"
  fi
  echo
}

# Parse a terraform apply log for "already exists - to be managed via
# Terraform" errors and `terraform import` each orphan into state.
# Returns 0 if at least one resource was imported (caller should retry
# apply), non-zero if there's nothing to import or all imports failed.
#
# Common trigger: previous failed apply created Azure resources but
# terraform errored before persisting them in state; the next apply
# sees them as "already exists" because Azure has them but state
# doesn't. Auto-import is non-destructive (vs auto-delete), so it's
# safe to default-on.
_auto_import_orphans() {
  local logfile="$1"
  local pairs
  pairs=$(python3 - "$logfile" <<'PY'
import re, sys
data = open(sys.argv[1]).read()
# The error block spans multiple lines:
#   │ Error: a resource with the ID "<ID>" already exists ...
#   │ ...
#   │   with module.range.azurerm_X.Y["key"],
# Match the ID then the next "with <addr>," within ~8 lines.
pat = re.compile(
    r'a resource with the ID "([^"]+)" already exists'
    r'[^\n]*(?:\n[^\n]*){1,8}?'
    # Resource address forms supported, in order of expected frequency:
    #   module.range.azurerm_*.<name>[...]      Azure (legacy default)
    #   module.range.google_*.<name>[...]       GCP
    #   module.range.aws_*.<name>[...]          AWS
    # Plain azurerm_X/google_X/aws_X (no module prefix) is also accepted
    # for direct-resource imports outside a module wrapper.
    r'with\s+(module\.[^\s,]+|azurerm_[^\s,]+|google_[^\s,]+|aws_[^\s,]+),',
    re.S,
)
seen = set()
for m in pat.finditer(data):
    key = (m.group(2), m.group(1))
    if key in seen:
        continue
    seen.add(key)
    print(f"{m.group(2)}|{m.group(1)}")
PY
  )
  if [[ -z "$pairs" ]]; then
    return 1
  fi
  local total
  total=$(echo "$pairs" | grep -c .)
  bold "Auto-importing $total orphan resource(s) into terraform state..."
  local imported=0 failed=0
  while IFS='|' read -r addr id; do
    [[ -z "$addr" || -z "$id" ]] && continue
    printf "  → %s\n" "$addr"
    if terraform import "$addr" "$id" >/dev/null 2>&1; then
      imported=$((imported + 1))
    else
      failed=$((failed + 1))
      warn "    [!] import failed — may need manual cleanup"
    fi
  done <<<"$pairs"
  bold "Imported $imported orphan(s), $failed failed."
  [[ "$imported" -gt 0 ]]
}

require_scenario() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "scenario name required (try './range list')"
  local path="$SCENARIO_DIR/$name.yaml"
  [[ -f "$path" ]] || die "no such scenario: $name (looked in $path)"
  echo "$path"
}

# ============================================================================
# _ensure_baked_images_exist <yaml> <force_yes>
# ============================================================================
# Pre-apply orchestration for fresh Azure accounts (and any deploy where
# a `use_baked_*: true` flag in the scenario doesn't yet have a version
# published in the Shared Image Gallery).
#
# Algorithm:
#   1. Parse the scenario YAML for every `use_baked_<x>: true` flag
#      under `baking:`. Map each to the SIG image_definition name +
#      the `./range bake <target>` invocation name.
#   2. Use `az sig image-version list` to check which definitions
#      have at least one version. Any with zero versions are
#      "missing" and would cause terraform apply to fail (the
#      data.azurerm_shared_image_version lookup errors when no
#      version exists).
#   3. If anything missing AND --no-auto-bake wasn't passed:
#      a. Prompt operator (unless --yes/--force): "Bake N images
#         (~30 min each) then apply?"
#      b. Run targeted `terraform apply` for ONLY the baking resources
#         (RG + gallery + every image definition slot). Cheap, ~1-2 min.
#         Required so packer has the image_definition to publish into.
#      c. For each missing target, invoke `./range bake <target>`.
#         Sequential — Azure parallelism quota would otherwise become
#         a footgun on a fresh account.
#   4. Return to caller; the main `terraform apply` flow continues
#      and now succeeds because every data.azurerm_shared_image_version
#      lookup resolves.
#
# Idempotent: subsequent runs detect "all versions present" and
# return immediately. Re-runs after a partial bake (some images baked,
# others failed mid-loop) resume from the missing ones.
#
# Skip with: --no-auto-bake on `./range apply`
_ensure_baked_images_exist() {
  local yaml_path="$1"
  local force_flag="${2:-0}"

  # GCP doesn't need the SIG-slot bootstrap pattern. On Azure we have
  # to pre-create the SIG gallery + image-definition slots before
  # Packer can publish into them. On GCP, `data.google_compute_image`
  # is a pure read — if the image-family doesn't exist yet, the apply
  # fails loudly with an actionable error ("bake first") and the
  # operator runs `./range --gcp bake <target>` (the bake creates the
  # image directly via Packer's googlecompute builder; no slot
  # pre-allocation needed). Skip the rest of this function on GCP.
  if [[ "$PROVIDER" == "gcp" ]]; then
    bold "  [auto-bake] GCP provider — skipping Azure-style SIG-slot bootstrap (not applicable)."
    bold "  [auto-bake]   If any data.google_compute_image lookup fails on plan, run ./range --gcp bake <target> for that image."
    return 0
  fi

  # AWS likewise doesn't use the SIG pattern.
  if [[ "$PROVIDER" == "aws" ]]; then
    return 0
  fi

  command -v az     >/dev/null 2>&1 || { warn "  [auto-bake] az not on PATH — skipping detection"; return 0; }
  command -v packer >/dev/null 2>&1 || { warn "  [auto-bake] packer not on PATH — skipping detection"; return 0; }

  # Read scenario YAML for enabled use_baked_* flags + the gallery
  # coordinates (rg + name). Emits TAB-separated:
  #   image_def_name<TAB>bake_target_name
  # on stdout, one per missing-or-not-yet-resolved baked image.
  local mapping
  mapping=$(python3 <<PYTHON
import sys, yaml
try:
    y = yaml.safe_load(open("$yaml_path"))
except Exception as e:
    print(f"# yaml parse error: {e}", file=sys.stderr)
    sys.exit(0)
b = (y.get("baking") or {})
if not b.get("enabled"):
    sys.exit(0)
# Mapping: use_baked_<flag> → (image_definition_name, bake_target_name)
# image_def name MUST match the name in modules/azure/baking.tf
# bake_target MUST match the case label in the bake) subcommand
M = {
    "use_baked_kali":              ("kali-redteam",        "kali"),
    "use_baked_win_server_2025":   ("win-server-2025",     "server-2025"),
    "use_baked_win_server_2022":   ("win-server-2022-ad",  "server-2022"),
    "use_baked_win_server_2019":   ("win-server-2019",     "server-2019"),
    "use_baked_win_10":            ("win-10",              "win-10"),
    "use_baked_win_11":            ("win-11",              "win-11"),
    "use_baked_elk":               ("elk",                 "elk"),
    "use_baked_redelk":            ("redelk",              "redelk"),
    "use_baked_debian_redirector": ("debian-redirector",   "debian-redirector"),
    "use_baked_guacamole":         ("guacamole",           "guacamole"),
    "use_baked_adaptix":           ("adaptix",             "adaptix"),
    "use_baked_mythic":            ("mythic",              "mythic"),
    "use_baked_sliver":            ("sliver",              "sliver"),
    "use_baked_ghostwriter":       ("ghostwriter",         "ghostwriter"),
    "use_baked_stepping_stones":   ("stepping-stones",     "stepping-stones"),
}
for flag, (img, target) in M.items():
    if b.get(flag):
        print(f"{img}\t{target}")
PYTHON
)
  if [[ -z "$mapping" ]]; then
    return 0   # no use_baked_*: true flags; nothing to bake
  fi

  local sig_rg sig_name
  sig_rg=$(python3 -c "import yaml; y=yaml.safe_load(open('$yaml_path')); print((y.get('baking') or {}).get('resource_group_name', 'terra-range-images-rg'))")
  sig_name=$(python3 -c "import yaml; y=yaml.safe_load(open('$yaml_path')); print((y.get('baking') or {}).get('gallery_name', 'terra_range_images'))")

  # Probe the gallery — is the RG even created yet? If not, EVERY
  # image is missing.
  local gallery_exists=1
  if ! az sig show -g "$sig_rg" -r "$sig_name" >/dev/null 2>&1; then
    gallery_exists=0
  fi

  # For each (image, target) pair, mark missing if version-list returns
  # empty.
  local missing_targets=()
  local missing_imgs=()
  while IFS=$'\t' read -r img target; do
    [[ -z "$img" ]] && continue
    local has_version=0
    if [[ "$gallery_exists" -eq 1 ]]; then
      if az sig image-version list -g "$sig_rg" -r "$sig_name" \
           --gallery-image-definition "$img" --query "[0].name" -o tsv 2>/dev/null \
           | grep -q .; then
        has_version=1
      fi
    fi
    if [[ "$has_version" -eq 0 ]]; then
      missing_targets+=("$target")
      missing_imgs+=("$img")
    else
      echo "  [auto-bake] $img: ✓ version exists, skipping"
    fi
  done <<<"$mapping"

  if [[ ${#missing_targets[@]} -eq 0 ]]; then
    bold "  [auto-bake] all baked images already published — nothing to do."
    return 0
  fi

  # Operator-visible summary + confirmation.
  echo
  bold "===================================================================="
  bold "  [auto-bake] Missing baked images that this scenario needs:"
  bold "===================================================================="
  local i=0
  while [[ $i -lt ${#missing_targets[@]} ]]; do
    printf "    - %-25s (target: ./range bake %s)\n" "${missing_imgs[$i]}" "${missing_targets[$i]}"
    i=$((i + 1))
  done
  bold ""
  bold "  Each bake takes ~20-45 min and runs sequentially."
  bold "  Estimated total bake time: ~$(( ${#missing_targets[@]} * 30 )) min."
  bold "  After baking completes, this apply will continue automatically."
  bold ""
  if [[ "$force_flag" -ne 1 ]]; then
    read -r -p "  Proceed with auto-bake-then-apply? Type 'yes' to continue: " confirm
    if [[ "$confirm" != "yes" ]]; then
      die "aborted by operator. To skip auto-bake, re-run with --no-auto-bake (and accept that the apply will fail until you bake manually)."
    fi
  else
    bold "  (--yes/--force passed → proceeding without prompt)"
  fi
  echo

  # Ensure SIG infrastructure exists. Targeted terraform apply — only
  # the baking RG + gallery + every image-definition slot. Cheap
  # (~1-2 min) and idempotent. Required because packer publishes
  # VERSIONS into existing image-definition slots; the slot must
  # already exist or packer's `shared_image_gallery_destination`
  # block errors with "image not found".
  bold "  [auto-bake] Ensuring SIG infra exists (targeted terraform apply, ~1-2 min) ..."
  cd "$ENV_DIR"
  [[ -d .terraform ]] || terraform init -upgrade
  terraform apply -auto-approve \
    -target='module.range.azurerm_resource_group.baking[0]' \
    -target='module.range.azurerm_shared_image_gallery.main[0]' \
    -target='module.range.azurerm_shared_image.kali_redteam[0]' \
    -target='module.range.azurerm_shared_image.kali_minimal[0]' \
    -target='module.range.azurerm_shared_image.win_server_2025[0]' \
    -target='module.range.azurerm_shared_image.win_server_2022_ad[0]' \
    -target='module.range.azurerm_shared_image.win_server_2019[0]' \
    -target='module.range.azurerm_shared_image.win_10[0]' \
    -target='module.range.azurerm_shared_image.win_11[0]' \
    -target='module.range.azurerm_shared_image.elk[0]' \
    -target='module.range.azurerm_shared_image.redelk[0]' \
    -target='module.range.azurerm_shared_image.debian_redirector[0]' \
    -target='module.range.azurerm_shared_image.guacamole[0]' \
    -target='module.range.azurerm_shared_image.adaptix[0]' \
    -target='module.range.azurerm_shared_image.mythic[0]' \
    -target='module.range.azurerm_shared_image.sliver[0]' \
    -target='module.range.azurerm_shared_image.ghostwriter[0]' \
    -target='module.range.azurerm_shared_image.stepping_stones[0]' \
    >/dev/null 2>&1 \
    || die "[auto-bake] SIG infra targeted apply failed — check 'terraform apply' output manually"
  bold "  [auto-bake] SIG infra ready."
  echo

  # Bake each missing target sequentially. Recursive self-invocation
  # via $0 — `./range bake <target>` is a first-class subcommand and
  # handles all the packer + az plumbing.
  local idx=0
  local total=${#missing_targets[@]}
  for target in "${missing_targets[@]}"; do
    idx=$((idx + 1))
    bold ""
    bold "===================================================================="
    bold "  [auto-bake] Bake $idx/$total: $target (~20-45 min) ..."
    bold "===================================================================="
    if ! "$0" bake "$target"; then
      die "[auto-bake] bake failed for '$target'. Re-run './range apply' to resume (already-baked images will be skipped)."
    fi
