import os, re
existing = os.environ.get('PIN', '')
skus = [s.strip() for s in os.environ.get('SKU_LIST', '').splitlines() if s.strip()]

def generalize(sku):
    if not sku:
        return None
    # Tokenize into digit/non-digit runs; escape literal chars,
    # replace digit runs with \d+. Result is a strict regex that
    # only matches SKUs of the same lexical shape.
