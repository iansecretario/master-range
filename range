import json, os, ssl, sys
import urllib.request, urllib.parse, urllib.error

URL  = os.environ["GUAC_URL"].rstrip("/")
USER = os.environ["GUAC_USER"]
PW   = os.environ["GUAC_PW"]
N    = int(os.environ["POOL_SIZE"])

# Self-signed-fallback tolerance: if the LE cert hasn't issued yet for
# this deploy, the Guac URL might be serving the bootstrap self-signed
# cert. Allow it — this is admin-API traffic over a private operator
# CIDR, not end-user traffic.
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def req(method, path, *, token=None, payload=None):
    body = None
    headers = {"Content-Type": "application/json"}
    if payload is not None:
        body = json.dumps(payload).encode()
    qs = f"?token={token}" if token else ""
    # nginx fronts Guacamole at the root path (no /guacamole/ prefix) —
    # see modules/azure/userdata/guacamole.sh nginx.conf. Keep paths as
    # received from the caller (/api/...).
    r = urllib.request.Request(f"{URL}{path}{qs}",
                               data=body, method=method, headers=headers)
    try:
        with urllib.request.urlopen(r, context=ctx, timeout=20) as resp:
            raw = resp.read()
            return resp.status, (json.loads(raw) if raw else None)
    except urllib.error.HTTPError as e:
        raw = e.read()
        try:
            return e.code, json.loads(raw)
        except Exception:
            return e.code, raw.decode("utf-8", "replace")

# 1) Authenticate.
data = urllib.parse.urlencode({"username": USER, "password": PW}).encode()
r = urllib.request.Request(f"{URL}/api/tokens", data=data, method="POST")
with urllib.request.urlopen(r, context=ctx, timeout=20) as resp:
    tok = json.loads(resp.read())["authToken"]
print(f"[auth] obtained admin token")

# 2) Find (or create) the shared-infra connection group. kali-2-<i>
# entries land here so the existing register.py shared-infra broadcast
# grant works for multi-student deploys.
_, groups = req("GET", "/api/session/data/postgresql/connectionGroups", token=tok)
gname_to_id = {v["name"]: k for k, v in (groups or {}).items()} \
              if isinstance(groups, dict) else {}
SHARED_GROUP = "shared-infra"
gid = gname_to_id.get(SHARED_GROUP)
if not gid:
    status, body = req("POST",
                       "/api/session/data/postgresql/connectionGroups",
                       token=tok,
                       payload={"parentIdentifier": "ROOT",
                                "name": SHARED_GROUP,
                                "type": "ORGANIZATIONAL",
                                "attributes": {}})
    if isinstance(body, dict) and "identifier" in body:
        gid = body["identifier"]
        print(f"[create] connection group: {SHARED_GROUP}")
    else:
        sys.exit(f"failed to create shared-infra group: {status} {body}")
else:
    print(f"[exists] connection group: {SHARED_GROUP}")

# 3) UPSERT each pool slot.
_, conns = req("GET", "/api/session/data/postgresql/connections", token=tok)
name_to_id = {v["name"]: k for k, v in (conns or {}).items()} \
             if isinstance(conns, dict) else {}

for i in range(1, N + 1):
    name = f"kali-2-{i}"
    payload = {
        "parentIdentifier": gid,
        "name": name,
        "protocol": "vnc",
        "parameters": {
            "hostname":    "10.0.1.50",
            "port":        str(5900 + i),
            # No password — the inner Xvnc runs SecurityTypes=None; the
            # host-port is restricted to the Guac VM IP by NSG.
            "username":    "",
            "password":    "",
            "color-depth": "24",
            "autoretry":   "3",
        },
        "attributes": {"max-connections": "10"},
    }
    if name in name_to_id:
        cid = name_to_id[name]
        status, body = req("PUT",
                           f"/api/session/data/postgresql/connections/{cid}",
                           token=tok, payload=payload)
        print(f"[update] {name}  (status={status})")
    else:
        status, body = req("POST",
                           "/api/session/data/postgresql/connections",
                           token=tok, payload=payload)
        print(f"[create] {name}  (status={status})")

print("done.")
PY
