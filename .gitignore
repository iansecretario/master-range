# Per-deploy lab artifacts (SSH keys, credentials.txt, etc).
# Each `./range apply <scenario>` creates labs/<range_name>/ with
# secrets in it; `./range destroy` cleans it up.
labs/

# Terraform plugin cache + lock file noise. .terraform.lock.hcl IS
# meant to be committed, but we keep the codebase provider-agnostic
# and let each clone re-resolve. Drop the `**` line below if you want
# to pin provider versions.
**/.terraform/
**/.terraform.lock.hcl
**/.terraform.tfstate.lock.info
**/terraform.tfstate
**/terraform.tfstate.*
**/.active-scenario
**/crash.log
# Single-file at the repo root (artifact from running terraform in $REPO directly)
/terraform.tfstate

# Per-env operator SSH keys (regenerated at apply time)
envs/*/operator-id_ed25519
envs/*/operator-id_ed25519.pub

# Per-env tfvars are GENERATED by ./range gen — not committed.
# Scenario definitions in scenarios/*.yaml are the source of truth.
envs/*/terraform.tfvars
envs/*/terraform.tfvars.json

# Packer build artefacts (manifests, build logs, override files)
packer/**/packer-manifest.json
packer/**/*.tmp
packer/**/build.log
/tmp/range-bake-override.*.tfvars.json

# Repair / health transcripts (go to /tmp by default)
/tmp/range-repair-*.log
/tmp/range-apply.*

# Generated python bytecode
__pycache__/
*.pyc
*.pyo

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Local-only secret files that operators may drop in the tree
*.env
.env.local
credentials.json
service-account-*.json
